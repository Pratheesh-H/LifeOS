// ---- RENDER TASK CARDS ----
let _taskSortMode = 'default';
function sortTasks(mode) {
  _taskSortMode = mode;
  const tasks = Store.get('dailyTasks', []).filter(t => t.date === today());
  document.getElementById('taskList').innerHTML = renderTasks(tasks, activeTaskFilter || 'all');
}

function renderTasks(tasks, filter = 'all') {
  let filtered = filter === 'all' ? tasks : tasks.filter(t => (t.questType || 'main') === filter);
  // Sort
  if (_taskSortMode === 'priority') filtered = [...filtered].sort((a,b) => (['high','medium','low'].indexOf(a.priority||'low')) - (['high','medium','low'].indexOf(b.priority||'low')));
  else if (_taskSortMode === 'xp') filtered = [...filtered].sort((a,b) => (XP_TABLE[b.priority||'low']) - (XP_TABLE[a.priority||'low']));
  else if (_taskSortMode === 'deadline') filtered = [...filtered].sort((a,b) => (a.deadline||'9999') < (b.deadline||'9999') ? -1 : 1);

  if (!filtered.length) return `<div class="empty"><div class="empty-icon">⚔️</div><div class="empty-text">NO QUESTS IN THIS CATEGORY<br/>CLICK "+ NEW QUEST" TO ADD MISSIONS</div></div>`;

  return filtered.map(t => {
    const qt = QUEST_TYPES[t.questType || 'main'];
    const xpVal = XP_TABLE[t.priority || 'low'];
    const isOverdue = t.deadline && !t.done && t.deadline < today();
    const isToday = t.deadline === today();
    return `<div class="quest-item ${t.done ? 'quest-done-row' : ''}" style="border-left:2px solid ${t.done ? 'var(--text3)' : qt.glow};padding-left:10px;${isOverdue ? 'background:rgba(255,68,68,0.03);' : ''}">
      <div class="quest-check ${t.done ? 'done' : ''}" onclick="toggleTask('${t.id}')"></div>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-bottom:4px">
          <span style="font-size:14px">${qt.icon}</span>
          <span class="quest-text ${t.done ? 'done' : ''}" style="font-size:14px">${t.text}</span>
          ${t.done ? `<span style="font-family:'Orbitron',monospace;font-size:9px;color:var(--success)">+${xpVal} XP ✓</span>` : `<span style="font-family:'Orbitron',monospace;font-size:9px;color:var(--text3)">+${xpVal} XP</span>`}
        </div>
        <div class="quest-meta">
          <span class="badge ${qt.color}">${qt.label}</span>
          <span class="badge b-${pcolor(t.priority)}">${(t.priority || 'low').toUpperCase()}</span>
          ${t.category ? `<span class="badge b-blue">${t.category.toUpperCase()}</span>` : ''}
          ${t.deadline ? `<span class="badge ${isOverdue ? 'b-red' : isToday ? 'b-orange' : 'b-gray'}">${isOverdue ? '⚠ OVERDUE' : isToday ? '⏰ DUE TODAY' : '📅 ' + fdate(t.deadline)}</span>` : ''}
          ${t.notifTime ? `<span class="badge b-teal">🔔 ${t.notifTime}</span>` : ''}
          ${t.estimatedTime ? `<span style="font-family:'Share Tech Mono',monospace;font-size:8px;color:var(--text3)">⏱ ${t.estimatedTime}min</span>` : ''}
        </div>
        ${t.notes ? `<div class="quest-notes" style="margin-top:6px">${t.notes}</div>` : ''}
      </div>
      <div class="fac gap4" style="flex-shrink:0">
        ${!t.done ? `<button class="btn btn-teal btn-xs" onclick="startQuestTimer('${t.id}')" style="color:var(--ds-teal);border-color:rgba(0,229,204,0.4);background:rgba(0,229,204,0.06);font-family:'Orbitron',monospace;font-size:7px;letter-spacing:1px;padding:3px 7px;border:1px solid;cursor:pointer">▶ START</button>` : ''}
        <button class="btn btn-ghost btn-xs" onclick="openAddTaskModal('${t.id}')">EDIT</button>
        <button class="btn btn-red btn-xs" onclick="delTask('${t.id}')">DEL</button>
      </div>
    </div>`;
  }).join('');
}

// ---- QUEST TIMER ----
let _activeTimer = null;
let _timerTaskId = null;
let _timerStart = null;
function startQuestTimer(id) {
  const tasks = Store.get('dailyTasks', []);
  const t = tasks.find(t => t.id === id);
  if (!t) return;
  if (_activeTimer) { clearInterval(_activeTimer); _activeTimer = null; }
  _timerTaskId = id;
  _timerStart = Date.now();

  // Show floating timer
  let existing = document.getElementById('questTimerFloat');
  if (existing) existing.remove();
  const tf = document.createElement('div');
  tf.id = 'questTimerFloat';
  tf.style.cssText = `position:fixed;bottom:70px;right:20px;z-index:1500;background:var(--panel);border:1px solid var(--sl-blue);box-shadow:0 0 20px var(--sl-glow);padding:14px 18px;min-width:220px;font-family:'Share Tech Mono',monospace;animation:notifIn 0.3s ease`;
  tf.innerHTML = `
    <div style="font-size:8px;letter-spacing:2px;color:var(--sl-blue);margin-bottom:6px">⚔️ QUEST IN PROGRESS</div>
    <div style="font-size:12px;color:var(--text);margin-bottom:8px">${t.text.slice(0,35)}${t.text.length>35?'...':''}</div>
    <div style="font-family:'Orbitron',monospace;font-size:24px;font-weight:700;color:var(--sl-blue);text-align:center;margin-bottom:10px" id="timerDisplay">00:00</div>
    <div style="display:flex;gap:6px">
      <button onclick="completeQuestFromTimer()" style="flex:1;font-family:'Orbitron',monospace;font-size:8px;letter-spacing:1px;padding:6px;border:1px solid var(--success);color:var(--success);background:rgba(0,255,136,0.08);cursor:pointer">✓ COMPLETE</button>
      <button onclick="stopQuestTimer()" style="font-family:'Orbitron',monospace;font-size:8px;letter-spacing:1px;padding:6px 10px;border:1px solid var(--text3);color:var(--text3);background:transparent;cursor:pointer">✕</button>
    </div>`;
  document.body.appendChild(tf);

  sendBrowserNotif('QUEST STARTED', `Now tracking: ${t.text}`, '⚔️');
  _activeTimer = setInterval(() => {
    const elapsed = Math.floor((Date.now() - _timerStart) / 1000);
    const m = String(Math.floor(elapsed / 60)).padStart(2, '0');
    const s = String(elapsed % 60).padStart(2, '0');
    const d = document.getElementById('timerDisplay');
    if (d) d.textContent = `${m}:${s}`;
  }, 1000);
}
function stopQuestTimer() {
  if (_activeTimer) { clearInterval(_activeTimer); _activeTimer = null; }
  const el = document.getElementById('questTimerFloat');
  if (el) el.remove();
}
function completeQuestFromTimer() {
  if (_timerTaskId) toggleTask(_timerTaskId);
  stopQuestTimer();
}

// ---- NOTIFICATION CONTROLS ----
async function toggleNotifications() {
  const enabled = Store.get('notifEnabled', false);
  if (!enabled) {
    const granted = await requestNotifPermission();
    if (granted) {
      showNotif('🔔 QUEST NOTIFICATIONS ACTIVATED', 'green');
      scheduleAllNotifs();
    } else {
      showNotif('❌ NOTIFICATION PERMISSION DENIED — CHECK BROWSER SETTINGS', 'red');
    }
  } else {
    Store.set('notifEnabled', false);
    Object.values(_notifTimers).forEach(t => clearTimeout(t));
    showNotif('🔕 NOTIFICATIONS DISABLED');
  }
  if (currentPage === 'daily') renderDaily();
}
function testNotification() {
  sendBrowserNotif('SYSTEM TEST', 'Quest notification system is operational!', '⚔️');
  showNotif('🔔 TEST NOTIFICATION SENT — CHECK YOUR BROWSER', 'green');
}

let activeTaskFilter = 'all';
function filterT(f, el) {
  activeTaskFilter = f;
