    <button onclick="this.parentElement.parentElement.remove()" style="margin-top:24px;font-family:'Orbitron',monospace;font-size:10px;letter-spacing:2px;padding:10px 28px;border:1px solid #ffd700;color:#ffd700;background:rgba(255,215,0,0.08);cursor:pointer">⟶ CONTINUE</button>
  </div>`;
  document.body.appendChild(b);
  setTimeout(() => { if (b.parentElement) b.remove(); }, 6000);
