async function sendAIMessage() {
  const input = document.getElementById('aiChatInput');
  const text = input.value.trim();
  if (!text || _aiTyping) return;

  input.value = '';
  input.style.height = 'auto';

  addAIMessage('user', text);
  _aiHistory.push({ role: 'user', content: text });

  showAITyping();
  _aiTyping = true;
  document.getElementById('aiSendBtn').disabled = true;

  try {
    // Build context snapshot of current app data
    const ctx = buildAppContext();
    const systemPrompt = buildSystemPrompt(ctx);

    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: systemPrompt,
        messages: _aiHistory
      })
    });

    const data = await response.json();
    const raw = data.content?.[0]?.text || '';

    hideAITyping();

    // Parse and execute the action
    let parsed = null;
    try {
      const jsonMatch = raw.match(/```json\s*([\s\S]*?)\s*```/) || raw.match(/(\{[\s\S]*\})/);
      if (jsonMatch) parsed = JSON.parse(jsonMatch[1]);
    } catch(e) {}

    if (parsed && parsed.action) {
      const result = executeAIAction(parsed);
      const replyText = parsed.reply || 'Done!';
      addAIMessage('assistant', replyText, result);
      _aiHistory.push({ role: 'assistant', content: raw });
    } else {
      // Pure text reply (e.g. AI asking for clarification)
      addAIMessage('assistant', raw.replace(/```json[\s\S]*?```/g, '').trim());
      _aiHistory.push({ role: 'assistant', content: raw });
    }

  } catch(err) {
    hideAITyping();
    addAIMessage('assistant', '⚠ Connection error. Check your internet and try again.');
    console.error('AI error:', err);
  }

  _aiTyping = false;
  document.getElementById('aiSendBtn').disabled = false;
}

