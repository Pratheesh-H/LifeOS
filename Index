const GDRIVE = {
  CLIENT_ID: '',   // filled by user in settings
  API_KEY:   '',   // filled by user in settings
  FILE_NAME: 'lifeos-cloudsave.json',
  SCOPES:    'https://www.googleapis.com/auth/drive.appdata',
  tokenClient: null,
  accessToken: null,
  fileId: null,
  ready: false,

  isConfigured() {
    const cfg = Store.get('gdriveConfig', {});
    return !!(cfg.clientId && cfg.apiKey);
  },

  loadConfig() {
    return Store.get('gdriveConfig', { clientId: '', apiKey: '' });
  },

  saveConfig(clientId, apiKey) {
    Store.set('gdriveConfig', { clientId, apiKey });
  },

  async init() {
    if (!this.isConfigured()) return false;
    const cfg = this.loadConfig();
    try {
      await new Promise((res, rej) => {
        gapi.load('client', { callback: res, onerror: rej });
      });
      await gapi.client.init({ apiKey: cfg.apiKey, discoveryDocs: ['https://www.googleapis.com/discovery/v1/apis/drive/v3/rest'] });
      this.tokenClient = google.accounts.oauth2.initTokenClient({
        client_id: cfg.clientId,
        scope: this.SCOPES,
        callback: (resp) => {
          if (resp.error) return;
          this.accessToken = resp.access_token;
          this.ready = true;
        }
      });
      return true;
    } catch(e) {
      console.error('GDRIVE init error:', e);
      return false;
    }
  },

  requestToken() {
    return new Promise((resolve) => {
      if (!this.tokenClient) { resolve(false); return; }
      const origCb = this.tokenClient.callback;
      this.tokenClient.callback = (resp) => {
        origCb(resp);
        resolve(!resp.error);
      };
      this.tokenClient.requestAccessToken({ prompt: '' });
    });
  },

  async findFile() {
    const resp = await gapi.client.drive.files.list({
      spaces: 'appDataFolder',
      q: `name='${this.FILE_NAME}'`,
      fields: 'files(id,name,modifiedTime)'
    });
    const files = resp.result.files;
    if (files && files.length > 0) {
      this.fileId = files[0].id;
      return files[0];
    }
    return null;
  },

  async uploadData() {
    const backup = { version: '2.0', savedAt: new Date().toISOString(), data: {} };
    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i);
      if (key && key.startsWith('los_') && key !== 'los_user' && key !== 'los_users') {
        try { backup.data[key.replace('los_','')] = JSON.parse(localStorage.getItem(key)); }
        catch(e) { backup.data[key.replace('los_','')] = localStorage.getItem(key); }
      }
    }
    const body = JSON.stringify(backup);
    const meta = { name: this.FILE_NAME, parents: this.fileId ? undefined : ['appDataFolder'] };

    if (this.fileId) {
      // Update existing
      await fetch(`https://www.googleapis.com/upload/drive/v3/files/${this.fileId}?uploadType=multipart`, {
        method: 'PATCH',
        headers: { Authorization: `Bearer ${this.accessToken}` },
        body: createMultipart(meta, body)
      });
    } else {
      // Create new
      const resp = await fetch('https://www.googleapis.com/upload/drive/v3/files?uploadType=multipart', {
        method: 'POST',
        headers: { Authorization: `Bearer ${this.accessToken}` },
        body: createMultipart(meta, body)
      });
      const data = await resp.json();
      this.fileId = data.id;
    }
    Store.set('lastCloudSync', new Date().toISOString());
  },

  async downloadData() {
    const file = await this.findFile();
    if (!file) return null;
    const resp = await fetch(`https://www.googleapis.com/drive/v3/files/${this.fileId}?alt=media`, {
      headers: { Authorization: `Bearer ${this.accessToken}` }
    });
    return await resp.json();
  }
};

function createMultipart(metadata, body) {
  const boundary = '-------lifeos_boundary';
  const delim = '\r\n--' + boundary + '\r\n';
  const closeDelim = '\r\n--' + boundary + '--';
  return new Blob([
    '--' + boundary + '\r\n',
    'Content-Type: application/json\r\n\r\n',
    JSON.stringify(metadata) + delim,
    'Content-Type: application/json\r\n\r\n',
    body + closeDelim
  ]);
}

async function cloudSyncSave() {
  if (!GDRIVE.isConfigured()) { openCloudSyncSetup(); return; }
  showNotif('☁ SYNCING TO GOOGLE DRIVE...', 'blue');
  try {
    const ok = await GDRIVE.init();
    if (!ok) throw new Error('Init failed');
    const tokenOk = await GDRIVE.requestToken();
    if (!tokenOk) throw new Error('Auth failed');
    await GDRIVE.findFile();
    await GDRIVE.uploadData();
    showNotif('✅ SYNCED TO GOOGLE DRIVE', 'green');
  } catch(e) {
    showNotif('❌ SYNC FAILED: ' + e.message, 'red');
  }
}

async function cloudSyncLoad() {
  if (!GDRIVE.isConfigured()) { openCloudSyncSetup(); return; }
  showNotif('☁ LOADING FROM GOOGLE DRIVE...', 'blue');
  try {
    const ok = await GDRIVE.init();
    if (!ok) throw new Error('Init failed');
    const tokenOk = await GDRIVE.requestToken();
    if (!tokenOk) throw new Error('Auth failed');
    const backup = await GDRIVE.downloadData();
    if (!backup || !backup.data) { showNotif('NO CLOUD SAVE FOUND', 'orange'); return; }
    let count = 0;
    Object.entries(backup.data).forEach(([key, val]) => {
      localStorage.setItem('los_' + key, JSON.stringify(val));
      count++;
    });
    showNotif('✅ RESTORED ' + count + ' KEYS FROM CLOUD — RELOADING...', 'green');
    setTimeout(() => location.reload(), 1800);
  } catch(e) {
    showNotif('❌ RESTORE FAILED: ' + e.message, 'red');
  }
}

