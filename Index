// ---- NOTIFICATION ENGINE ----
let _notifPermission = 'default';
async function requestNotifPermission() {
  if (!('Notification' in window)) return false;
  const res = await Notification.requestPermission();
  _notifPermission = res;
  Store.set('notifEnabled', res === 'granted');
  return res === 'granted';
}
function sendBrowserNotif(title, body, icon='⚔️') {
  if (!('Notification' in window) || Notification.permission !== 'granted') return;
  new Notification(`${icon} ${title}`, { body, icon: '/favicon.ico', badge: '/favicon.ico' });
}
// Scheduled notification via setTimeout (session-based)
const _notifTimers = {};
function scheduleQuestNotif(task) {
  if (!task.notifTime || Store.get('notifEnabled') !== true) return;
  if (_notifTimers[task.id]) { clearTimeout(_notifTimers[task.id]); delete _notifTimers[task.id]; }
  const [h, m] = task.notifTime.split(':').map(Number);
  const now = new Date();
  const fire = new Date(now.getFullYear(), now.getMonth(), now.getDate(), h, m, 0);
  const diff = fire - now;
  if (diff > 0 && diff < 86400000) {
    _notifTimers[task.id] = setTimeout(() => {
      sendBrowserNotif('QUEST REMINDER', `${task.text} — Time to level up!`, '⚔️');
      showNotif(`⏰ QUEST REMINDER: ${task.text.slice(0,40)}`, 'default');
    }, diff);
  }
}
function scheduleAllNotifs() {
  Store.get('dailyTasks', []).filter(t => t.date === today() && !t.done).forEach(scheduleQuestNotif);
}

// ---- XP & AURA SYSTEM ----
const XP_TABLE = { high: 50, medium: 30, low: 15 };
const PENALTY_TABLE = { high: -30, medium: -15, low: -8 };
const AURA_TABLE = { high: 20, medium: 10, low: 5 };
const LEVEL_XP = [0,100,250,450,700,1000,1400,1900,2500,3200,4000];

function getPlayerData() {
  return Store.get('playerData', { xp: 0, aura: 0, level: 1, totalXP: 0, streak: 0, lastActive: '', achievements: [] });
}
function savePlayerData(d) { Store.set('playerData', d); }

function addXP(amount, reason='') {
  const p = getPlayerData();
  p.xp = (p.xp || 0) + amount;
  p.totalXP = (p.totalXP || 0) + Math.max(0, amount);
  if (p.xp < 0) p.xp = 0;
  // Level up check
  const nextLvl = LEVEL_XP[Math.min(p.level, LEVEL_XP.length - 1)];
  if (p.xp >= nextLvl && p.level < 10) {
    p.level += 1; p.xp = p.xp - nextLvl;
    showLevelUpBanner(p.level);
    sendBrowserNotif('LEVEL UP!', `You reached Level ${p.level}! The System acknowledges your growth.`, '🌟');
  }
  savePlayerData(p);
  updatePlayerStats();
}
function addAura(amount) {
  const p = getPlayerData();
  p.aura = Math.max(0, (p.aura || 0) + amount);
  savePlayerData(p);
}
function updateStreak() {
  const p = getPlayerData();
  const t = today();
  const yesterday = new Date(); yesterday.setDate(yesterday.getDate() - 1);
  const yStr = yesterday.toISOString().split('T')[0];
  if (p.lastActive === yStr) { p.streak = (p.streak || 0) + 1; }
  else if (p.lastActive !== t) { p.streak = 1; }
  p.lastActive = t;
  savePlayerData(p);
}
function showLevelUpBanner(lvl) {
  const b = document.createElement('div');
  b.style.cssText = `position:fixed;inset:0;z-index:9000;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.85);backdrop-filter:blur(12px);animation:modalIn 0.3s ease`;
  b.innerHTML = `<div style="text-align:center">
    <div style="font-family:'Share Tech Mono',monospace;font-size:12px;letter-spacing:4px;color:var(--sl-blue);margin-bottom:16px">⟦ SYSTEM NOTIFICATION ⟧</div>
    <div style="font-family:'Orbitron',monospace;font-size:13px;letter-spacing:3px;color:var(--text3);margin-bottom:8px">CONGRATULATIONS, HUNTER</div>
    <div style="font-family:'Orbitron',monospace;font-size:52px;font-weight:900;color:#ffd700;text-shadow:0 0 40px rgba(255,215,0,0.8);animation:logoPulse 1s infinite">LV.${lvl}</div>
    <div style="font-family:'Rajdhani',sans-serif;font-size:20px;font-weight:700;color:var(--text);margin-top:12px;letter-spacing:2px">YOU HAVE LEVELED UP</div>
