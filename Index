function updateDiet(k, v) { Store.merge('dietData', { [k]: parseFloat(v) }); }
function logWater(g) {
  const max = Store.get('dietData', {}).waterTarget || 8;
  const cur = Store.get('waterToday_' + today(), 0);
  const newVal = g === -1 ? Math.max(0, cur - 1) : Math.min(Math.max(0, g), max);
  Store.set('waterToday_' + today(), newVal);
  Store.merge('fitnessData', { waterToday: newVal });
  renderDiet();
}
