function executeAIAction(parsed) {
  const { action, data } = parsed;
  const t = today();

  try {
    if (action === 'add_task') {
      const tasks = Store.get('dailyTasks', []);
      const task = {
        id: uid(), text: data.text, priority: data.priority || 'medium',
        questType: data.questType || 'main', category: data.category || '',
        deadline: data.deadline || '', notes: data.notes || '',
        notifTime: data.notifTime || '', date: t, done: false
      };
      tasks.push(task);
      Store.set('dailyTasks', tasks);
      if (currentPage === 'daily') renderDaily();
      return { type: 'task', label: 'QUEST ADDED', details: `"${data.text}" — ${(data.priority||'medium').toUpperCase()} PRIORITY`, page: 'daily', pageLabel: '→ VIEW IN DAILY QUESTS' };
    }

    if (action === 'add_note') {
      const notes = Store.get('notes', []);
      notes.unshift({ id: uid(), title: data.title, content: data.content, tag: data.tag || 'general', date: t, pinned: false });
      Store.set('notes', notes);
      if (currentPage === 'notes') renderNotes();
      return { type: 'note', label: 'NOTE SAVED', details: `"${data.title}"`, page: 'notes', pageLabel: '→ VIEW IN HUNTER JOURNAL' };
    }

    if (action === 'add_course') {
      const courses = Store.get('courses', []);
      courses.push({ id: uid(), title: data.title, platform: data.platform || '', category: data.category || '', totalHours: data.totalHours || 0, progress: data.progress || 0, status: data.status || 'active', started: t });
      Store.set('courses', courses);
      if (currentPage === 'courses') renderCourses();
      return { type: 'course', label: 'SKILL SCROLL ADDED', details: `"${data.title}" on ${data.platform||'Unknown'}`, page: 'courses', pageLabel: '→ VIEW IN SKILL SCROLLS' };
    }

    if (action === 'add_habit') {
      const habits = Store.get('habits', []);
      habits.push({ id: uid(), name: data.name, category: data.category || 'personal', icon: data.icon || '🔁', targetDays: data.targetDays || 7, streak: 0, log: {} });
      Store.set('habits', habits);
      if (currentPage === 'monthly') renderMonthly();
      return { type: 'habit', label: 'HABIT PROTOCOL ADDED', details: `"${data.name}"`, page: 'monthly', pageLabel: '→ VIEW IN ARC GOALS' };
    }

    if (action === 'add_goal') {
      const goals = Store.get('monthlyGoals', []);
      goals.push({ id: uid(), title: data.title, category: data.category || 'personal', priority: data.priority || 'medium', deadline: data.deadline || '', done: false, milestones: [], date: t });
      Store.set('monthlyGoals', goals);
      if (currentPage === 'monthly') renderMonthly();
      return { type: 'goal', label: 'MISSION OBJECTIVE SET', details: `"${data.title}"`, page: 'monthly', pageLabel: '→ VIEW IN ARC GOALS' };
    }

    if (action === 'add_workout') {
      const workouts = Store.get('workouts', []);
      workouts.push({ id: uid(), name: data.name, sets: data.sets || 3, reps: data.reps || 10, weight: data.weight || '', category: data.category || 'full body', date: t });
      Store.set('workouts', workouts);
      if (currentPage === 'fitness') renderFitness();
      return { type: 'workout', label: 'TRAINING LOGGED', details: `${data.name} — ${data.sets||3}x${data.reps||10}`, page: 'fitness', pageLabel: '→ VIEW IN BODY STATS' };
    }

    if (action === 'add_meal') {
      const meals = Store.get('meals', []);
      meals.push({ id: uid(), name: data.name, calories: data.calories || 0, protein: data.protein || 0, carbs: data.carbs || 0, fat: data.fat || 0, mealType: data.mealType || 'lunch', date: t });
      Store.set('meals', meals);
      if (currentPage === 'diet') renderDiet();
      return { type: 'meal', label: 'MANA LOGGED', details: `${data.name} — ${data.calories||0} kcal`, page: 'diet', pageLabel: '→ VIEW IN MANA RECOVERY' };
    }

    if (action === 'add_interview') {
      const interviews = Store.get('interviews', []);
      interviews.push({ id: uid(), company: data.company, role: data.role, date: data.date || t, status: data.status || 'Applied', notes: data.notes || '', platform: data.platform || '', created: t });
      Store.set('interviews', interviews);
      if (currentPage === 'interviews') renderInterviews();
      return { type: 'interview', label: 'BOSS BATTLE REGISTERED', details: `${data.role} @ ${data.company}`, page: 'interviews', pageLabel: '→ VIEW IN BOSS BATTLES' };
    }

    if (action === 'add_yearly_goal') {
      const goals = Store.get('yearlyGoals', []);
      goals.push({ id: uid(), title: data.title, category: data.category || 'personal', targetDate: data.targetDate || '', progress: 0, done: false });
      Store.set('yearlyGoals', goals);
      if (currentPage === 'yearly') renderYearly();
      return { type: 'yearly', label: 'SEASON TARGET SET', details: `"${data.title}"`, page: 'yearly', pageLabel: '→ VIEW IN SEASON TARGETS' };
    }

    if (action === 'navigate') {
      navigate(data.page);
      return null;
    }

    if (action === 'summary') {
      return null;
    }

  } catch(e) {
    console.error('AI action error:', e);
  }
  return null;
}

function addAIMessage(role, text, actionResult = null, scroll = true) {
  const container = document.getElementById('aiChatMessages');
  const div = document.createElement('div');
  div.className = `ai-msg ${role}`;

  const label = document.createElement('div');
  label.className = 'ai-msg-label';
  label.textContent = role === 'user' ? 'YOU' : '⚡ SYSTEM AI';

  const bubble = document.createElement('div');
  bubble.className = 'ai-bubble';
  // Convert newlines to <br>
  bubble.innerHTML = text.replace(/\n/g, '<br>');

  // Attach action confirmation card
  if (actionResult) {
    const card = document.createElement('div');
    card.className = 'ai-action-card';
    card.innerHTML = `<div class="ai-action-title">✅ ${actionResult.label}</div>${actionResult.details}`;
    if (actionResult.page) {
      const navBtn = document.createElement('div');
      navBtn.className = 'ai-nav-btn';
      navBtn.textContent = actionResult.pageLabel;
      navBtn.onclick = () => { navigate(actionResult.page); toggleAIChat(); };
      card.appendChild(navBtn);
    }
    bubble.appendChild(card);
  }

  div.appendChild(label);
  div.appendChild(bubble);
  container.appendChild(div);

  if (scroll) container.scrollTop = container.scrollHeight;
}

