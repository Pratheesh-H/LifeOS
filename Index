function exportBackup() {
  const backup = { version: '2.0', exportedAt: new Date().toISOString(), data: {} };

  // Grab every los_ key from localStorage
  for (let i = 0; i < localStorage.length; i++) {
    const key = localStorage.key(i);
    if (key && key.startsWith('los_') && key !== 'los_user' && key !== 'los_users') {
      try {
        backup.data[key.replace('los_', '')] = JSON.parse(localStorage.getItem(key));
      } catch(e) {
        backup.data[key.replace('los_', '')] = localStorage.getItem(key);
      }
    }
  }

  const json = JSON.stringify(backup, null, 2);
  const blob = new Blob([json], { type: 'application/json' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  const date = new Date().toISOString().slice(0,10);
  a.href     = url;
  a.download = `lifeos-backup-${date}.json`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  showNotif('✅ BACKUP DOWNLOADED — KEEP THIS FILE SAFE', 'green');
}

function importBackup() {
  const input = document.createElement('input');
  input.type = 'file';
  input.accept = '.json';
  input.onchange = function(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(ev) {
      try {
        const backup = JSON.parse(ev.target.result);
        if (!backup.data) throw new Error('Invalid backup file');
        let count = 0;
        Object.entries(backup.data).forEach(([key, val]) => {
          localStorage.setItem('los_' + key, JSON.stringify(val));
          count++;
        });
        showNotif('✅ RESTORED ' + count + ' DATA KEYS — RELOADING...', 'green');
        setTimeout(() => location.reload(), 1500);
      } catch(err) {
        showNotif('❌ INVALID BACKUP FILE: ' + err.message, 'red');
      }
    };
    reader.readAsText(file);
  };
  document.body.appendChild(input);
  input.click();
  document.body.removeChild(input);
}

