function saveCourse(eid) {
  const name = document.getElementById('cName').value.trim();
  if (!name) { showNotif('COURSE NAME REQUIRED', 'red'); return; }
  const done = parseInt(document.getElementById('cDone').value) || 0;
  const total = parseInt(document.getElementById('cTotal').value) || 1;
  const courses = Store.get('courses', []);
  const nc = {
    id: eid || uid(), name,
    platform: document.getElementById('cPlat').value.trim(),
    instructor: document.getElementById('cInst').value.trim(),
    category: document.getElementById('cCat').value,
    status: document.getElementById('cStatus').value,
    totalModules: total, modulesCompleted: done,
    progress: pct(done, total),
    totalHours: parseInt(document.getElementById('cHours').value) || 0,
    startDate: document.getElementById('cStart').value,
    deadline: document.getElementById('cDeadline').value,
    url: document.getElementById('cUrl').value.trim(),
    notes: document.getElementById('cNotes').value.trim(),
  };
  if (nc.status === 'completed') nc.progress = 100;
  if (eid) { const i = courses.findIndex(c => c.id === eid); if (i > -1) courses[i] = nc; }
  else courses.push(nc);
  Store.set('courses', courses);
  closeModal();
  showNotif('COURSE SAVED', 'green');
  renderCourses();
}

function updateCourseProgress(id, val) {
  const courses = Store.get('courses', []);
  const c = courses.find(c => c.id === id);
  if (c) {
    c.progress = parseInt(val);
    if (c.totalModules) c.modulesCompleted = Math.round(c.totalModules * val / 100);
    Store.set('courses', courses);
    // Update the % display next to slider
    const card = document.querySelector(`[data-course-id="${id}"]`);
  }
}

function markCourseComplete(id) {
  const courses = Store.get('courses', []);
  const c = courses.find(c => c.id === id);
  if (c) {
    c.status = 'completed'; c.progress = 100;
    if (c.totalModules) c.modulesCompleted = c.totalModules;
    c.completedDate = today();
    Store.set('courses', courses);
    showNotif('🎉 COURSE COMPLETE! NOW ADD YOUR CERTIFICATION FOR XP', 'green');
    renderCourses();
  }
}

function setCourseStatus(id, status) {
  const courses = Store.get('courses', []);
  const c = courses.find(c => c.id === id);
  if (c) { c.status = status; Store.set('courses', courses); renderCourses(); }
}

function delCourse(id) {
  Store.set('courses', Store.get('courses', []).filter(c => c.id !== id));
  showNotif('COURSE REMOVED');
  renderCourses();
}

