function buildAnalystContext() {
  const today_str = today();
  const now = new Date();
  const thisMonth = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;

  // Tasks
  const allTasks    = Store.get('dailyTasks', []);
  const todayTasks  = allTasks.filter(t => t.date === today_str);
  const doneTasks   = todayTasks.filter(t => t.done);
  const pendingHigh = todayTasks.filter(t => !t.done && t.priority === 'high');

  // Goals
  const monthly  = Store.get('monthlyGoals', []);
  const yearly   = Store.get('yearlyGoals', []);
  const fiveYear = Store.get('fiveYearGoals', []);
  const doneMonthly = monthly.filter(g => g.done);
  const doneYearly  = yearly.filter(g => g.done);

  // Fitness
  const workouts   = Store.get('workouts', []);
  const thisWeekWO = workouts.filter(w => { const d=new Date(w.date); return d >= new Date(now - 7*864e5); });
  const fitnessData = Store.get('fitnessData', {});

  // Diet
  const dietData = Store.get('dietData', {});
  const waterToday = Store.get('waterToday_'+today_str, 0);

  // Finance
  const txns       = Store.get('financeTxns', []);
  const monthTxns  = txns.filter(t => t.date && t.date.startsWith(thisMonth));
  const income     = monthTxns.filter(t=>t.type==='income').reduce((s,t)=>s+t.amount,0);
  const expense    = monthTxns.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const budgets    = Store.get('financeBudgets', []);
  const savings    = Store.get('financeSavings', []);
  const overspent  = budgets.filter(b => {
    const spent = monthTxns.filter(t=>t.type==='expense'&&t.category===b.category).reduce((s,t)=>s+t.amount,0);
    return spent > b.limit;
  });

  // Courses & certs
  const courses = Store.get('courses', []);
  const certs   = Store.get('certifications', []);
  const activeCourses    = courses.filter(c=>c.status==='active');
  const completedCourses = courses.filter(c=>c.status==='completed');
  const claimedCerts     = certs.filter(c=>c.claimed);

  // Career
  const interviews  = Store.get('interviews', []);
  const placements  = Store.get('placements', []);
  const pendingInts = interviews.filter(i=>i.status==='scheduled'||i.status==='pending');
  const offers      = interviews.filter(i=>i.status==='offer');

  // Notes
  const notes = Store.get('notes', []);

  // Player
  const player = Store.get('playerData', {xp:0,level:1,streak:0});

  return {
    player: { level: player.level||1, xp: player.xp||0, streak: player.streak||0, totalXP: player.totalXP||0 },
    tasks: {
      totalToday: todayTasks.length, completed: doneTasks.length,
      completionRate: todayTasks.length ? Math.round((doneTasks.length/todayTasks.length)*100) : 0,
      pendingHighPriority: pendingHigh.length,
      allTimeDone: allTasks.filter(t=>t.done).length
    },
    goals: {
      monthly: { total: monthly.length, done: doneMonthly.length },
      yearly:  { total: yearly.length,  done: doneYearly.length },
      fiveYear:{ total: fiveYear.length }
    },
    fitness: {
      workoutsThisWeek: thisWeekWO.length,
      totalWorkouts: workouts.length,
      currentWeight: fitnessData.weight || null,
      targetWeight: fitnessData.targetWeight || null,
      waterCupsToday: waterToday
    },
    finance: {
      monthlyIncome: income, monthlyExpense: expense,
      netBalance: income - expense,
      overspentCategories: overspent.map(b=>b.category),
      totalSavingsGoals: savings.length,
      savingsProgress: savings.length ? Math.round(savings.reduce((s,g)=>s+(g.saved/g.target),0)/savings.length*100) : 0
    },
    learning: {
      activeCourses: activeCourses.length,
      completedCourses: completedCourses.length,
      certifications: certs.length,
      claimedCertXP: claimedCerts.reduce((s,c)=>s+(CERT_XP[c.rarity]||100),0)
    },
    career: {
      totalInterviews: interviews.length,
      pendingInterviews: pendingInts.length,
      offers: offers.length,
      placements: placements.length
    },
    notes: { total: notes.length },
    generatedAt: new Date().toLocaleString('en-IN')
  };
}

