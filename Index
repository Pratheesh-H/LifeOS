#aiChatPanel {
  position: fixed;
  bottom: 160px; right: 12px;
  width: min(400px, calc(100vw - 24px));
  max-height: min(520px, calc(100vh - 180px));
  z-index: 499;
  background: rgba(5,11,20,0.98);
  border: 1px solid var(--sl-blue);
  box-shadow: 0 0 40px var(--sl-glow), 0 20px 60px rgba(0,0,0,0.8);
  display: none;
  flex-direction: column;
  overflow: hidden;
  animation: chatSlideIn 0.25s ease;
  backdrop-filter: blur(16px);
}
#aiChatPanel.open { display: flex; }
@keyframes chatSlideIn {
  from { opacity: 0; transform: translateY(20px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
#aiChatPanel::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--sl-blue), var(--jjk-purple2), var(--sl-blue), transparent);
}
#aiChatHeader {
  padding: 12px 14px;
  border-bottom: 1px solid var(--border-dim);
  display: flex; justify-content: space-between; align-items: center;
  background: rgba(0,180,255,0.04);
  flex-shrink: 0;
}
#aiChatMessages {
  flex: 1;
  overflow-y: auto;
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  scroll-behavior: smooth;
}
#aiChatMessages::-webkit-scrollbar { width: 3px; }
#aiChatMessages::-webkit-scrollbar-thumb { background: var(--border-glow); }
.ai-msg { display: flex; flex-direction: column; gap: 4px; animation: msgIn 0.2s ease; }
@keyframes msgIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}
.ai-msg.user { align-items: flex-end; }
.ai-msg.assistant { align-items: flex-start; }
.ai-bubble {
  max-width: 88%;
  padding: 9px 13px;
  font-family: 'Rajdhani', sans-serif;
  font-size: 13px;
  line-height: 1.5;
  border: 1px solid;
}
.ai-msg.user .ai-bubble {
  background: rgba(0,180,255,0.1);
  border-color: rgba(0,180,255,0.3);
  color: var(--text);
  border-radius: 12px 12px 2px 12px;
}
.ai-msg.assistant .ai-bubble {
  background: rgba(139,92,246,0.08);
  border-color: rgba(139,92,246,0.25);
  color: var(--text);
  border-radius: 12px 12px 12px 2px;
}
.ai-msg-label {
  font-family: 'Share Tech Mono', monospace;
  font-size: 8px;
  letter-spacing: 1px;
  color: var(--text3);
  padding: 0 4px;
}
.ai-action-card {
  margin-top: 8px;
  padding: 8px 10px;
  border: 1px solid rgba(0,229,204,0.3);
  background: rgba(0,229,204,0.05);
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  color: var(--ds-teal);
  line-height: 1.8;
}
.ai-action-title {
  font-family: 'Orbitron', monospace;
  font-size: 8px;
  letter-spacing: 2px;
  color: var(--ds-teal);
  margin-bottom: 5px;
}
.ai-nav-btn {
  display: inline-block;
  margin-top: 8px;
  padding: 4px 10px;
  border: 1px solid var(--sl-blue);
  color: var(--sl-blue);
  background: rgba(0,180,255,0.06);
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  letter-spacing: 1px;
  cursor: pointer;
  transition: all 0.15s;
}
.ai-nav-btn:hover { background: rgba(0,180,255,0.15); }
.ai-typing { display: flex; align-items: center; gap: 4px; padding: 10px 14px; }
.ai-typing span {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--jjk-purple2);
  animation: typingBounce 1.2s infinite;
}
.ai-typing span:nth-child(2) { animation-delay: 0.2s; }
.ai-typing span:nth-child(3) { animation-delay: 0.4s; }
@keyframes typingBounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
  30% { transform: translateY(-6px); opacity: 1; }
}
#aiQuickChips {
  display: flex; flex-wrap: wrap; gap: 5px;
  padding: 8px 12px;
  border-top: 1px solid var(--border-dim);
  border-bottom: 1px solid var(--border-dim);
  background: rgba(0,0,0,0.2);
  flex-shrink: 0;
}
.ai-chip {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  padding: 4px 9px;
  border: 1px solid var(--border-dim);
  color: var(--text3);
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.ai-chip:hover { border-color: var(--sl-blue); color: var(--sl-blue); background: rgba(0,180,255,0.06); }
#aiChatInputRow {
  display: flex; align-items: flex-end; gap: 8px;
  padding: 10px 12px;
  background: rgba(0,0,0,0.3);
  flex-shrink: 0;
}
#aiChatInput {
  flex: 1;
  background: rgba(0,180,255,0.04);
  border: 1px solid var(--border-dim);
  color: var(--text);
  font-family: 'Rajdhani', sans-serif;
  font-size: 13px;
  padding: 8px 10px;
  resize: none;
  outline: none;
  min-height: 36px;
  max-height: 80px;
  transition: border-color 0.2s;
  line-height: 1.4;
}
#aiChatInput:focus { border-color: rgba(0,180,255,0.5); }
#aiChatInput::placeholder { color: var(--text3); font-size: 11px; }
#aiSendBtn {
  width: 36px; height: 36px;
  background: linear-gradient(135deg, var(--sl-blue2), var(--sl-blue));
  border: none; color: white;
  font-family: 'Orbitron', monospace; font-size: 14px;
  cursor: pointer; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  transition: opacity 0.2s;
}
#aiSendBtn:disabled { opacity: 0.4; cursor: not-allowed; }
#aiSendBtn:hover:not(:disabled) { opacity: 0.85; }
@media (max-width: 480px) {
  #aiChatBtn { bottom: 80px; right: 14px; width: 46px; height: 46px; font-size: 20px; }
  #aiChatPulse { width: 46px; height: 46px; }
  #aiChatPanel { bottom: 160px; right: 8px; left: 8px; width: auto; max-height: calc(100vh - 180px); }
}

/* RANK DISPLAY */
.rank-badge {
  display: inline-flex; align-items: center; justify-content: center;
  width: 36px; height: 36px;
  border: 2px solid;
  font-family: 'Orbitron', monospace;
  font-size: 14px; font-weight: 900;
  position: relative;
}
.rank-s { border-color: #ffd700; color: #ffd700; box-shadow: 0 0 15px rgba(255,215,0,0.4); }
.rank-a { border-color: var(--jjk-purple2); color: var(--jjk-purple2); box-shadow: 0 0 15px var(--jjk-glow); }
.rank-b { border-color: var(--sl-blue); color: var(--sl-blue); box-shadow: 0 0 15px var(--sl-glow); }
.rank-c { border-color: var(--success); color: var(--success); }
.rank-d { border-color: var(--nrt-orange); color: var(--nrt-orange); }
.rank-e { border-color: var(--text3); color: var(--text3); }

/* COURSE CARD */
.course-card {
  border: 1px solid var(--border-dim);
  background: rgba(8,15,28,0.9);
  padding: 16px; transition: all 0.3s;
  position: relative; overflow: hidden;
}
.course-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
}
.course-card:hover {
  border-color: var(--border-glow);
  box-shadow: 0 0 20px rgba(0,180,255,0.08);
}
.course-name { font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 15px; color: var(--text); margin-bottom: 4px; }
.course-platform { font-family: 'Share Tech Mono', monospace; font-size: 9px; color: var(--text3); letter-spacing: 1px; margin-bottom: 12px; }

/* NOTE CARD */
.note-card {
  border: 1px solid var(--border-dim);
  padding: 16px; cursor: pointer; transition: all 0.2s;
  position: relative;
}
.note-card:hover { border-color: var(--border-glow); transform: translateY(-2px); }
.note-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; }
.nc-blue::before { background: linear-gradient(90deg, var(--sl-blue2), transparent); }
.nc-purple::before { background: linear-gradient(90deg, var(--jjk-purple), transparent); }
.nc-orange::before { background: linear-gradient(90deg, var(--nrt-orange), transparent); }
.nc-teal::before { background: linear-gradient(90deg, var(--ds-teal), transparent); }
.nc-red::before { background: linear-gradient(90deg, var(--aot-red), transparent); }
.nc-pink::before { background: linear-gradient(90deg, var(--ds-pink), transparent); }
.note-title { font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 14px; color: var(--text); margin-bottom: 6px; }
.note-content { font-size: 12px; color: var(--text3); line-height: 1.6; font-family: 'Exo 2', sans-serif; }

/* SCROLL */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: var(--void); }
::-webkit-scrollbar-thumb { background: var(--border-glow); }
::-webkit-scrollbar-thumb:hover { background: var(--sl-blue); }

/* SEARCH */
.search-wrap { position: relative; }
.search-wrap .sys-field { padding-left: 34px; }
.search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text3); font-size: 13px; pointer-events: none; }

/* DIVIDER */
.div { height: 1px; background: var(--border-dim); margin: 12px 0; }

/* TABLE */
.sys-table { width: 100%; border-collapse: collapse; }
.sys-table th {
  font-family: 'Share Tech Mono', monospace;
  font-size: 8px; letter-spacing: 2px; color: var(--text3);
  text-align: left; padding: 8px 10px;
  border-bottom: 1px solid var(--border-dim);
  text-transform: uppercase;
}
.sys-table td {
  padding: 10px 10px;
  border-bottom: 1px solid rgba(255,255,255,0.02);
  font-size: 13px;
  transition: background 0.15s;
}
.sys-table tr:hover td { background: rgba(0,180,255,0.03); }
.sys-table td:first-child { font-family: 'Rajdhani', sans-serif; font-weight: 700; color: var(--text); }

/* INPUT RANGE */
input[type=range] {
  -webkit-appearance: none;
  width: 100%; height: 4px;
  background: rgba(0,180,255,0.1);
  outline: none; border: 1px solid var(--border-dim);
  cursor: pointer; margin-top: 8px;
}
input[type=range]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 12px; height: 12px;
  background: var(--sl-blue);
  box-shadow: 0 0 8px var(--sl-glow);
  cursor: pointer; transform: rotate(45deg);
}

/* LEVEL UP ANIMATION */
@keyframes levelUp {
  0% { transform: scale(0.5); opacity: 0; }
  50% { transform: scale(1.2); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}
.level-up { animation: levelUp 0.5s ease forwards; }
