// ============ PLAYER STATS UI ============
function updatePlayerStats() {
  const p = getPlayerData();
  const lvl = p.level || 1;
  const curXP = p.xp || 0;
  const nextXP = LEVEL_XP[Math.min(lvl, LEVEL_XP.length - 1)];
  const score = Math.min(Math.round((curXP / nextXP) * 100), 100);

  const ranks = [
    {r:'S',t:'▲ SHADOW MONARCH',min:9},
    {r:'A',t:'▲ NATIONAL LEVEL HUNTER',min:7},
    {r:'B',t:'▲ AWAKENED ELITE',min:5},
    {r:'C',t:'▲ DUNGEON RAIDER',min:3},
    {r:'D',t:'▲ GATE EXPLORER',min:2},
    {r:'E',t:'▲ AWAKENED NOVICE',min:0}
  ];
  const rank = ranks.find(r => lvl >= r.min) || ranks[ranks.length - 1];

  const rankEl  = document.getElementById('playerRank');
  const titleEl = document.getElementById('playerTitle');
  const xpFill  = document.getElementById('xpFill');
  const xpVal   = document.getElementById('xpVal');

  if (rankEl)  { rankEl.textContent = rank.r; rankEl.className = 'rank-badge rank-' + rank.r.toLowerCase(); }
  if (titleEl) titleEl.textContent = rank.t;
  if (xpFill)  xpFill.style.width = score + '%';
  if (xpVal)   xpVal.textContent = `LV.${lvl} — ${curXP}/${nextXP} XP`;
}

