  // Parse sections from rawText
  const sections = [];
  const lines = rawText.split('\n');
  let currentSection = null;
  let currentLines = [];
  for (const line of lines) {
    const headerMatch = line.match(/⟦\s*(.+?)\s*⟧/);
    if (headerMatch) {
      if (currentSection) sections.push({ title: currentSection, body: currentLines.join('\n').trim() });
      currentSection = headerMatch[1];
      currentLines = [];
    } else {
      currentLines.push(line);
    }
  }
  if (currentSection) sections.push({ title: currentSection, body: currentLines.join('\n').trim() });

  // Section icons
  const iconMap = {
    'OVERALL':'⚡','STATUS':'⚡','DAILY':'📋','MISSION':'🎯','BODY':'💪','COMBAT':'💪',
    'GOLD':'💰','VAULT':'💰','FINANCE':'💰','SKILL':'📚','DEVELOPMENT':'📚',
    'CAREER':'⚔','BATTLEFIELD':'⚔','INTELLIGENCE':'🧠','ASSESSMENT':'🧠',
    'OPERATIONS':'📋','PROGRESS':'🎯','ANALYSIS':'💰'
  };
  // Accent colours per section
  const accentColors = ['#00b4ff','#22c55e','#f97316','#a78bfa','#ffd700','#00e5cc','#ef4444','#00b4ff'];

  // Extract key points from each section body
  function extractKeyPoints(body) {
    const pts = [];
    const sentenceRx = /[A-Z][^.!?]*[.!?]/g;
    const matched = body.match(sentenceRx) || [];
    // Grab up to 3 most meaningful sentences (avoid very short ones)
    matched.filter(s => s.length > 40).slice(0, 3).forEach(s => pts.push(s.trim()));
    return pts;
  }

  // Extract recommendation line
  function extractRecommendation(body) {
    const lines = body.split('\n');
    for (const l of lines) {
      const t = l.trim();
      if (t.match(/^(RECOMMENDATION|ACTION|TACTICAL|→|▸)/i) || t.toLowerCase().startsWith('recommendation')) {
        return t.replace(/^(RECOMMENDATION:|ACTION:|TACTICAL:|→|▸)\s*/i,'').trim();
      }
    }
    // Last sentence as fallback
    const sentences = body.match(/[A-Z][^.!?]*[.!?]/g) || [];
    return sentences[sentences.length-1] || '';
  }

