    </div>`;
  });

  // Footer
  html += `
  <div style="text-align:center;padding:16px 0 24px">
    <div style="font-family:'Share Tech Mono',monospace;font-size:8px;color:var(--text3);letter-spacing:2px;margin-bottom:14px">// END OF INTELLIGENCE REPORT</div>
