<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>LifeOS // SYSTEM INTERFACE v2.0</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&family=Orbitron:wght@400;500;600;700;800;900&family=Exo+2:wght@100;200;300;400;500;600;700;800&family=Share+Tech+Mono&display=swap" rel="stylesheet"/>
<style>
/* ============================================================
   SOLO LEVELING / ANIME SYSTEM UI — LIFEOS
   Inspired by: Solo Leveling, Attack on Titan, JJK, Naruto, 
   Demon Slayer, Re:Zero
   ============================================================ */

:root {
  --void: #020408;
  --abyss: #050b14;
  --deep: #080f1c;
  --panel: #0a1628;
  --panel2: #0d1e35;
  --glass: rgba(10,22,40,0.85);
  --border-glow: #1a4a8a;
  --border-dim: #0f2a4a;

  /* Solo Leveling Blue */
  --sl-blue: #00b4ff;
  --sl-blue2: #0080ff;
  --sl-glow: rgba(0,180,255,0.4);
  --sl-dim: rgba(0,180,255,0.08);

  /* AOT Crimson */
  --aot-red: #c0392b;
  --aot-red2: #ff4444;
  --aot-glow: rgba(192,57,43,0.5);

  /* JJK Purple */
  --jjk-purple: #8b5cf6;
  --jjk-purple2: #a78bfa;
  --jjk-glow: rgba(139,92,246,0.4);

  /* Naruto Orange */
  --nrt-orange: #ff6b00;
  --nrt-glow: rgba(255,107,0,0.4);

  /* Demon Slayer */
  --ds-teal: #00e5cc;
  --ds-pink: #ff2d7a;

  /* Text */
  --text: #c8e8ff;
  --text2: #6a9ec0;
  --text3: #2a5070;
  --text-bright: #ffffff;

  /* System */
  --success: #00ff88;
  --warning: #ffcc00;
  --danger: #ff3355;

  --radius: 4px;
  --radius2: 2px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

/* SCANLINE + GRAIN EFFECT */
body::before {
  content: '';
  position: fixed; inset: 0; z-index: 9999;
  pointer-events: none;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0,0,0,0.03) 2px,
    rgba(0,0,0,0.03) 4px
  );
}
body::after {
  content: '';
  position: fixed; inset: 0; z-index: 9998;
  pointer-events: none;
  background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.7) 100%);
}

body {
  font-family: 'Exo 2', sans-serif;
  background: var(--void);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ANIMATED BG */
.bg-grid {
  position: fixed; inset: 0; z-index: 0;
  background-image:
    linear-gradient(rgba(0,180,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,180,255,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  animation: gridShift 20s linear infinite;
}
@keyframes gridShift {
  from { background-position: 0 0; }
  to { background-position: 40px 40px; }
}

.bg-particles {
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
}

/* FLOATING RUNE ANIMATIONS */
.rune {
  position: fixed;
  font-family: 'Orbitron', monospace;
  font-size: 10px;
  color: rgba(0,180,255,0.15);
  pointer-events: none;
  z-index: 1;
  animation: runeFloat linear infinite;
}
@keyframes runeFloat {
  from { transform: translateY(100vh) rotate(0deg); opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  to { transform: translateY(-20px) rotate(360deg); opacity: 0; }
}

/* ============ AUTH SCREEN ============ */

/* ============ AUTH SCREEN — REDESIGNED ============ */
.auth-screen {
  position: fixed; inset: 0; z-index: 100;
  display: flex; align-items: center; justify-content: center;
  background: #020810; overflow: hidden;
}
.auth-bg-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(0,180,255,0.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,180,255,0.035) 1px, transparent 1px);
  background-size: 40px 40px;
  animation: gridScroll 20s linear infinite;
}
@keyframes gridScroll { from{transform:translateY(0)} to{transform:translateY(40px)} }
.auth-bg-glow {
  position: absolute; inset: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 70% 55% at 50% 40%, rgba(0,128,255,0.07) 0%, transparent 65%),
    radial-gradient(ellipse 35% 40% at 10% 85%, rgba(139,92,246,0.05) 0%, transparent 60%),
    radial-gradient(ellipse 30% 35% at 90% 15%, rgba(0,229,204,0.04) 0%, transparent 55%);
}
.auth-particles { position:absolute; inset:0; overflow:hidden; pointer-events:none; }
.auth-particle {
  position:absolute; width:2px; height:2px;
  background:var(--sl-blue); border-radius:50%; opacity:0;
  animation: pFloat var(--dur,8s) var(--delay,0s) infinite linear;
}
@keyframes pFloat {
  0%  { opacity:0; transform:translateY(100vh) translateX(0); }
  10% { opacity:0.5; }
  90% { opacity:0.5; }
  100%{ opacity:0; transform:translateY(-10vh) translateX(var(--drift,20px)); }
}
.auth-card {
  position:relative; z-index:2;
  width:420px; max-width:calc(100vw - 32px);
  background:rgba(3,10,22,0.94);
  border:1px solid rgba(0,180,255,0.2);
  backdrop-filter:blur(20px);
  animation:authCardIn 0.6s cubic-bezier(0.22,1,0.36,1) both;
  box-shadow: 0 0 0 1px rgba(0,180,255,0.04), 0 40px 80px rgba(0,0,0,0.7), 0 0 60px rgba(0,128,255,0.06), inset 0 1px 0 rgba(0,180,255,0.08);
}
@keyframes authCardIn {
  from{opacity:0;transform:translateY(28px) scale(0.96);filter:blur(6px)}
  to  {opacity:1;transform:translateY(0) scale(1);filter:none}
}
.auth-card::before,.auth-card::after {
  content:''; position:absolute;
  width:18px; height:18px;
  border-color:var(--sl-blue); border-style:solid; opacity:0.6;
}
.auth-card::before{ top:-1px; left:-1px; border-width:2px 0 0 2px; }
.auth-card::after { bottom:-1px; right:-1px; border-width:0 2px 2px 0; }
.auth-topbar {
  display:flex; align-items:center; justify-content:space-between;
  padding:10px 20px;
  background:linear-gradient(90deg,rgba(0,128,255,0.12),rgba(0,180,255,0.04));
  border-bottom:1px solid rgba(0,180,255,0.12);
}
.auth-topbar-title {
  font-family:'Share Tech Mono',monospace;
  font-size:9px; letter-spacing:3px; color:rgba(0,180,255,0.8);
}
.auth-topbar-dots { display:flex; gap:5px; }
.auth-topbar-dot {
  width:6px; height:6px; border-radius:50%;
  animation:dotPulse 2s infinite;
}
.auth-topbar-dot:nth-child(1){background:#ef4444;animation-delay:0s}
.auth-topbar-dot:nth-child(2){background:#f97316;animation-delay:0.3s}
.auth-topbar-dot:nth-child(3){background:#22c55e;animation-delay:0.6s}
@keyframes dotPulse{0%,100%{opacity:1}50%{opacity:0.25}}
.auth-body { padding:28px 28px 24px; }
.auth-logo-wrap { text-align:center; margin-bottom:24px; }
.auth-logo-icon {
  font-family:'Orbitron',monospace; font-size:38px; font-weight:900;
  color:var(--sl-blue); display:block; line-height:1; letter-spacing:2px;
  text-shadow:0 0 20px rgba(0,180,255,0.5),0 0 40px rgba(0,180,255,0.15);
  animation:logoPulse 4s ease-in-out infinite;
}
.auth-logo-tagline {
  font-family:'Share Tech Mono',monospace; font-size:8.5px; letter-spacing:4px;
  color:rgba(139,180,220,0.45); margin-top:7px;
}
.auth-logo-line {
  width:60px; height:1px; margin:10px auto 0;
  background:linear-gradient(90deg,transparent,var(--sl-blue),transparent);
  animation:lineExp 2s ease-in-out infinite alternate;
}
@keyframes lineExp{from{width:40px;opacity:0.4}to{width:90px;opacity:0.9}}
.auth-switcher {
  display:flex;
  background:rgba(0,180,255,0.03);
  border:1px solid rgba(0,180,255,0.1);
  margin-bottom:24px; overflow:hidden;
}
.auth-switch-btn {
  flex:1; padding:10px 0;
  background:transparent; border:none;
  font-family:'Orbitron',monospace; font-size:9px; letter-spacing:3px;
  color:var(--text3); cursor:pointer; transition:all 0.2s;
  box-shadow:inset 0 -2px 0 transparent;
}
.auth-switch-btn.active {
  background:rgba(0,180,255,0.09); color:var(--sl-blue);
  text-shadow:0 0 10px rgba(0,180,255,0.4);
  box-shadow:inset 0 -2px 0 var(--sl-blue);
}
.auth-switch-btn:not(.active):hover{ color:var(--text2); }
.auth-form { display:none; }
.auth-form.active {
  display:block;
  animation:formIn 0.28s cubic-bezier(0.22,1,0.36,1) both;
}
@keyframes formIn{from{opacity:0;transform:translateX(12px)}to{opacity:1;transform:translateX(0)}}
.auth-field { margin-bottom:16px; }
.auth-label {
  font-family:'Share Tech Mono',monospace; font-size:9px; letter-spacing:2.5px;
  color:rgba(139,180,220,0.5); display:block; margin-bottom:6px;
}
.auth-input-wrap { position:relative; }
.auth-input {
  width:100%; box-sizing:border-box;
  background:rgba(0,180,255,0.03);
  border:1px solid rgba(0,180,255,0.12);
  border-left:2px solid rgba(0,128,255,0.35);
  color:var(--text);
  font-family:'Share Tech Mono',monospace; font-size:13px;
  padding:11px 38px 11px 13px; outline:none; transition:all 0.2s;
  -webkit-appearance:none;
}
.auth-input:focus {
  border-color:rgba(0,180,255,0.4); border-left-color:var(--sl-blue);
  background:rgba(0,180,255,0.055);
  box-shadow:0 0 0 3px rgba(0,180,255,0.05),0 0 16px rgba(0,180,255,0.05);
}
.auth-input.error {
  border-color:rgba(239,68,68,0.45)!important; border-left-color:#ef4444!important;
  background:rgba(239,68,68,0.035)!important;
  box-shadow:0 0 0 3px rgba(239,68,68,0.05)!important;
}
.auth-input.valid {
  border-color:rgba(34,197,94,0.35)!important; border-left-color:#22c55e!important;
}
.auth-input::placeholder{ color:rgba(74,96,128,0.5); }
.auth-eye-btn {
  position:absolute; right:11px; top:50%; transform:translateY(-50%);
  background:none; border:none; cursor:pointer;
  color:rgba(74,96,128,0.6); padding:4px; font-size:14px; line-height:1;
  transition:color 0.2s;
}
.auth-eye-btn:hover{ color:var(--sl-blue); }
.auth-field-error {
  font-family:'Share Tech Mono',monospace; font-size:8.5px; color:#ef4444;
  margin-top:4px; letter-spacing:1px; display:none;
}
.auth-field-error.show{ display:block; animation:errIn 0.18s ease; }
@keyframes errIn{from{opacity:0;transform:translateY(-3px)}to{opacity:1;transform:translateY(0)}}
.auth-strength-wrap{ margin-top:5px; display:none; }
.auth-strength-wrap.show{ display:block; }
.auth-strength-bar { height:3px; background:rgba(0,180,255,0.07); overflow:hidden; }
.auth-strength-fill { height:100%; width:0%; transition:width 0.3s,background 0.3s; }
.auth-strength-text {
  font-family:'Share Tech Mono',monospace; font-size:8px; letter-spacing:2px;
  margin-top:3px; color:var(--text3);
}
.auth-submit {
  width:100%; padding:13px; margin-top:6px;
  background:transparent; border:1px solid var(--sl-blue);
  color:var(--sl-blue); font-family:'Orbitron',monospace;
  font-size:10.5px; letter-spacing:4px; cursor:pointer;
  transition:all 0.22s; position:relative; overflow:hidden;
}
.auth-submit::before {
  content:''; position:absolute; top:0; left:-100%; width:100%; height:100%;
  background:linear-gradient(90deg,transparent,rgba(0,180,255,0.14),transparent);
  transition:left 0.45s;
}
.auth-submit:hover::before{ left:100%; }
.auth-submit:hover {
  background:rgba(0,180,255,0.09);
  box-shadow:0 0 22px rgba(0,180,255,0.18),inset 0 0 20px rgba(0,180,255,0.04);
  text-shadow:0 0 10px rgba(0,180,255,0.6); transform:translateY(-1px);
}
.auth-submit:active{ transform:translateY(0); }
.auth-submit.loading{ pointer-events:none; opacity:0.65; }
.auth-submit.loading::after {
  content:''; position:absolute; right:14px; top:50%; transform:translateY(-50%);
  width:13px; height:13px; border:2px solid rgba(0,180,255,0.25);
  border-top-color:var(--sl-blue); border-radius:50%;
  animation:spin 0.75s linear infinite;
}
@keyframes spin{ to{ transform:translateY(-50%) rotate(360deg); } }
.auth-footer {
  text-align:center; margin-top:18px;
  font-family:'Share Tech Mono',monospace; font-size:9px; letter-spacing:1.5px; color:var(--text3);
}
.auth-footer-link {
  color:var(--sl-blue); cursor:pointer; transition:text-shadow 0.2s;
}
.auth-footer-link:hover{ text-shadow:0 0 8px rgba(0,180,255,0.5); }
.auth-scanline {
  height:2px;
  background:linear-gradient(90deg,transparent,var(--sl-blue),transparent);
  animation:scanM 3s ease-in-out infinite; opacity:0.45;
}
@keyframes scanM{0%,100%{transform:scaleX(0.2);opacity:0.2}50%{transform:scaleX(1);opacity:0.7}}


.auth-notice-box {
  border: 1px solid rgba(0,180,255,0.15);
  background: rgba(0,180,255,0.03);
  padding: 10px 13px; margin-bottom: 16px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 9.5px; color: rgba(0,180,255,0.65);
  line-height: 1.8; letter-spacing: 0.5px;
}
/* ============ MAIN LAYOUT ============ */
.app { display: flex; min-height: 100vh; position: relative; z-index: 10; }

/* MAIN CONTENT */
.main {
  flex: 1; width: 100%;
  min-height: 100vh; background: transparent;
}

.topbar {
  height: 52px;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 24px;
  border-bottom: 1px solid var(--border-dim);
  background: rgba(5,11,20,0.9);
  backdrop-filter: blur(10px);
  position: sticky; top: 0; z-index: 40;
}
.topbar::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--sl-blue), transparent);
  opacity: 0.5;
}

.topbar-left { display: flex; align-items: center; gap: 16px; }
.page-id {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px; letter-spacing: 2px; color: var(--text3);
}
.page-name {
  font-family: 'Orbitron', monospace;
  font-size: 13px; font-weight: 600;
  color: var(--sl-blue);
  text-shadow: 0 0 10px var(--sl-glow);
  letter-spacing: 1px;
}
.topbar-right { display: flex; align-items: center; gap: 10px; }

.sys-clock {
  font-family: 'Share Tech Mono', monospace;
  font-size: 12px; color: var(--text2);
  border: 1px solid var(--border-dim);
  padding: 4px 10px;
  background: rgba(0,180,255,0.03);
}

.icon-sys-btn {
  width: 32px; height: 32px;
  border: 1px solid var(--border-dim);
  background: rgba(0,180,255,0.03);
  color: var(--text2); cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; transition: all 0.2s;
}
.icon-sys-btn:hover {
  border-color: var(--sl-blue); color: var(--sl-blue);
  box-shadow: 0 0 10px var(--sl-glow);
}

/* PAGE */
.page { padding: 20px 24px; max-width: 1600px; overflow-x: hidden; }

/* PANELS */
.panel {
  background: rgba(8,15,28,0.8);
  border: 1px solid var(--border-dim);
  position: relative; overflow: hidden;
  backdrop-filter: blur(5px);
}
.panel::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--sl-blue), transparent);
  opacity: 0.5;
}
.panel-corner {
  position: absolute;
  width: 12px; height: 12px;
  border-color: var(--sl-blue);
  border-style: solid;
}
.pc-tl { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
.pc-tr { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
.pc-bl { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; }
.pc-br { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }

.panel-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 16px;
  border-bottom: 1px solid var(--border-dim);
  background: rgba(0,180,255,0.03);
}
.panel-title {
  font-family: 'Orbitron', monospace;
  font-size: 11px; letter-spacing: 2px;
  color: var(--sl-blue); font-weight: 600;
  text-transform: uppercase;
}
.panel-body { padding: 16px; }

/* STAT CARDS */
.stat-grid { display: grid; gap: 12px; }
.stat-card {
  padding: 16px;
  border: 1px solid var(--border-dim);
  background: rgba(8,15,28,0.9);
  position: relative; overflow: hidden;
  transition: all 0.3s;
  cursor: default;
}
.stat-card:hover {
  border-color: var(--sl-blue);
  box-shadow: 0 0 20px var(--sl-glow);
  transform: translateY(-2px);
}
.stat-card::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
}
.sc-blue::after   { background: linear-gradient(90deg, transparent, var(--sl-blue), transparent); }
.sc-green::after  { background: linear-gradient(90deg, transparent, #22c55e, transparent); }
.sc-purple::after { background: linear-gradient(90deg, transparent, var(--jjk-purple), transparent); }
.sc-red::after { background: linear-gradient(90deg, transparent, var(--aot-red2), transparent); }
.sc-orange::after { background: linear-gradient(90deg, transparent, var(--nrt-orange), transparent); }
.sc-teal::after { background: linear-gradient(90deg, transparent, var(--ds-teal), transparent); }
.sc-pink::after { background: linear-gradient(90deg, transparent, var(--ds-pink), transparent); }

.sc-label {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px; letter-spacing: 2px;
  color: var(--text3); margin-bottom: 8px;
  text-transform: uppercase;
}
.sc-value {
  font-family: 'Orbitron', monospace;
  font-size: 26px; font-weight: 700;
  line-height: 1;
}
.sc-blue .sc-value { color: var(--sl-blue); text-shadow: 0 0 15px var(--sl-glow); }
.sc-purple .sc-value { color: var(--jjk-purple2); text-shadow: 0 0 15px var(--jjk-glow); }
.sc-red .sc-value { color: var(--aot-red2); text-shadow: 0 0 15px var(--aot-glow); }
.sc-orange .sc-value { color: var(--nrt-orange); text-shadow: 0 0 15px var(--nrt-glow); }
.sc-teal .sc-value { color: var(--ds-teal); text-shadow: 0 0 15px rgba(0,229,204,0.4); }
.sc-pink  .sc-value { color: var(--ds-pink); text-shadow: 0 0 15px rgba(255,45,122,0.4); }
.sc-green .sc-value { color: #22c55e; text-shadow: 0 0 15px rgba(34,197,94,0.4); }
.sc-sub {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px; color: var(--text3); margin-top: 8px;
}
.sc-icon {
  position: absolute; right: 12px; top: 12px;
  font-size: 22px; opacity: 0.4;
}

/* PROGRESS BARS */
.sys-bar-wrap { margin-bottom: 12px; }
.sys-bar-top {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 5px;
}
.sys-bar-label {
  font-family: 'Rajdhani', sans-serif;
  font-size: 12px; font-weight: 600; color: var(--text);
  letter-spacing: 0.5px;
}
.sys-bar-val {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px; color: var(--text2);
}
.sys-bar {
  height: 6px;
  background: rgba(0,180,255,0.05);
  border: 1px solid var(--border-dim);
  position: relative;
}
.sys-bar-fill {
  height: 100%;
  position: relative; overflow: hidden;
  transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}
.sys-bar-fill::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  animation: barShine 2s linear infinite;
}
@keyframes barShine {
  from { transform: translateX(-100%); }
  to { transform: translateX(100%); }
}
.bar-blue .sys-bar-fill { background: linear-gradient(90deg, var(--sl-blue2), var(--sl-blue)); box-shadow: 0 0 8px var(--sl-glow); }
.bar-purple .sys-bar-fill { background: linear-gradient(90deg, #7c3aed, var(--jjk-purple2)); box-shadow: 0 0 8px var(--jjk-glow); }
.bar-red .sys-bar-fill { background: linear-gradient(90deg, var(--aot-red), var(--aot-red2)); box-shadow: 0 0 8px var(--aot-glow); }
.bar-orange .sys-bar-fill { background: linear-gradient(90deg, #cc5500, var(--nrt-orange)); box-shadow: 0 0 8px var(--nrt-glow); }
.bar-teal .sys-bar-fill { background: linear-gradient(90deg, #00b8a0, var(--ds-teal)); box-shadow: 0 0 8px rgba(0,229,204,0.4); }
.bar-pink .sys-bar-fill { background: linear-gradient(90deg, #cc1060, var(--ds-pink)); }

/* BADGES */
.badge {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px; letter-spacing: 1px;
  padding: 2px 8px; text-transform: uppercase;
  border-width: 1px; border-style: solid;
  display: inline-block;
}
.b-blue { color: var(--sl-blue); border-color: rgba(0,180,255,0.4); background: rgba(0,180,255,0.07); }
.b-purple { color: var(--jjk-purple2); border-color: rgba(139,92,246,0.4); background: rgba(139,92,246,0.07); }
.b-red { color: var(--aot-red2); border-color: rgba(255,68,68,0.4); background: rgba(255,68,68,0.07); }
.b-orange { color: var(--nrt-orange); border-color: rgba(255,107,0,0.4); background: rgba(255,107,0,0.07); }
.b-teal { color: var(--ds-teal); border-color: rgba(0,229,204,0.4); background: rgba(0,229,204,0.07); }
.b-pink { color: var(--ds-pink); border-color: rgba(255,45,122,0.4); background: rgba(255,45,122,0.07); }
.b-gray { color: var(--text3); border-color: var(--border-dim); background: transparent; }
.b-green { color: var(--success); border-color: rgba(0,255,136,0.4); background: rgba(0,255,136,0.07); }

/* QUEST ITEMS (Tasks) */
.quest-item {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid rgba(255,255,255,0.03);
  transition: all 0.2s;
}
.quest-item:hover { background: rgba(0,180,255,0.02); padding-left: 6px; }
.quest-item:last-child { border-bottom: none; }

.quest-check {
  width: 16px; height: 16px; flex-shrink: 0;
  margin-top: 2px;
  border: 1px solid var(--border-glow);
  background: transparent; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s; position: relative;
  transform: rotate(45deg);
}
.quest-check:hover { border-color: var(--sl-blue); box-shadow: 0 0 8px var(--sl-glow); }
.quest-check.done {
  background: var(--sl-blue2);
  border-color: var(--sl-blue);
  box-shadow: 0 0 10px var(--sl-glow);
}
.quest-check.done::after {
  content: '✓';
  color: white; font-size: 9px; font-weight: 700;
  transform: rotate(-45deg);
}

.quest-text {
  font-family: 'Rajdhani', sans-serif;
  font-size: 14px; font-weight: 500; flex: 1;
  color: var(--text); letter-spacing: 0.3px;
}
.quest-text.done {
  text-decoration: line-through;
  color: var(--text3);
}
.quest-meta {
  display: flex; gap: 6px; align-items: center; flex-wrap: wrap;
  margin-top: 4px;
}
.quest-notes {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px; color: var(--text3);
  margin-top: 6px; padding: 6px 10px;
  border-left: 2px solid var(--border-glow);
  background: rgba(0,180,255,0.03);
}

/* BUTTONS */
.btn {
  font-family: 'Orbitron', monospace;
  font-size: 9px; letter-spacing: 2px;
  padding: 8px 16px;
  border: 1px solid; cursor: pointer;
  transition: all 0.2s; text-transform: uppercase;
  position: relative; overflow: hidden;
  display: inline-flex; align-items: center; gap: 6px;
}
.btn::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
  transform: translateX(-100%);
}
.btn:hover::before { transform: translateX(100%); transition: transform 0.4s; }
.btn-sm { padding: 5px 10px; font-size: 8px; letter-spacing: 1px; }
.btn-xs { padding: 3px 8px; font-size: 7px; letter-spacing: 1px; }

.btn-blue { color: var(--sl-blue); border-color: rgba(0,180,255,0.5); background: rgba(0,180,255,0.06); }
.btn-blue:hover { background: rgba(0,180,255,0.15); box-shadow: 0 0 15px var(--sl-glow); text-shadow: 0 0 8px var(--sl-glow); }
.btn-purple { color: var(--jjk-purple2); border-color: rgba(139,92,246,0.5); background: rgba(139,92,246,0.06); }
.btn-purple:hover { background: rgba(139,92,246,0.15); box-shadow: 0 0 15px var(--jjk-glow); }
.btn-red { color: var(--aot-red2); border-color: rgba(255,68,68,0.4); background: rgba(255,68,68,0.06); }
.btn-red:hover { background: rgba(255,68,68,0.15); }
.btn-orange { color: var(--nrt-orange); border-color: rgba(255,107,0,0.4); background: rgba(255,107,0,0.06); }
.btn-orange:hover { background: rgba(255,107,0,0.15); box-shadow: 0 0 15px var(--nrt-glow); }
.btn-ghost { color: var(--text3); border-color: var(--border-dim); background: transparent; }
.btn-ghost:hover { color: var(--text); border-color: var(--border-glow); }

/* INPUTS */
.sys-field {
  width: 100%;
  background: rgba(0,180,255,0.03);
  border: 1px solid var(--border-dim);
  border-left: 2px solid var(--border-glow);
  color: var(--text);
  font-family: 'Exo 2', sans-serif;
  font-size: 13px; padding: 9px 12px;
  outline: none; transition: all 0.2s;
}
.sys-field:focus {
  border-color: rgba(0,180,255,0.5);
  border-left-color: var(--sl-blue);
  background: rgba(0,180,255,0.06);
  box-shadow: 0 0 15px rgba(0,180,255,0.08);
}
.sys-field::placeholder { color: var(--text3); font-size: 12px; }
textarea.sys-field { resize: vertical; min-height: 80px; }
select.sys-field { appearance: none; cursor: pointer; }

.field-label {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px; letter-spacing: 2px;
  color: var(--text3); text-transform: uppercase;
  display: block; margin-bottom: 6px;
}
.field-group { margin-bottom: 14px; }

/* GRID */
.g { display: grid; gap: 12px; }
.g2 { grid-template-columns: repeat(2,1fr); }
.g3 { grid-template-columns: repeat(3,1fr); }
.g4 { grid-template-columns: repeat(4,1fr); }
.ga { grid-template-columns: repeat(auto-fill, minmax(260px,1fr)); }
.mb8 { margin-bottom: 8px; } .mb10 { margin-bottom: 10px; } .mb12 { margin-bottom: 12px; }
.mb16 { margin-bottom: 16px; } .mb20 { margin-bottom: 20px; }
.mb24 { margin-bottom: 24px; }
.flex { display: flex; }
.fbc { display:flex; align-items:center; justify-content:space-between; }
.fac { display:flex; align-items:center; }
.gap4 { gap:4px; } .gap8 { gap:8px; } .gap12 { gap:12px; } .gap16 { gap:16px; }

/* MODAL */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.85);
  backdrop-filter: blur(8px);
  z-index: 1000;
  display: flex; align-items: center; justify-content: center;
  padding: 20px;
}
.modal {
  background: var(--abyss);
  border: 1px solid var(--sl-blue);
  width: 500px; max-width: 100%;
  max-height: 90vh; overflow-y: auto;
  position: relative;
  box-shadow: 0 0 50px var(--sl-glow), 0 0 100px rgba(0,180,255,0.1);
  animation: modalIn 0.3s ease;
  clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
}
@keyframes modalIn {
  from { opacity: 0; transform: scale(0.9) translateY(20px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}
.modal-header {
  background: linear-gradient(90deg, rgba(0,180,255,0.15), transparent);
  padding: 12px 20px;
  border-bottom: 1px solid rgba(0,180,255,0.3);
  display: flex; align-items: center; justify-content: space-between;
}
.modal-title {
  font-family: 'Orbitron', monospace;
  font-size: 12px; letter-spacing: 2px;
  color: var(--sl-blue); text-transform: uppercase;
}
.modal-body { padding: 20px; }
.modal-footer { display: flex; gap: 8px; justify-content: flex-end; padding: 16px 20px; border-top: 1px solid var(--border-dim); }

/* KANBAN */
.kanban {
  display: flex; gap: 12px;
  overflow-x: auto; overflow-y: visible;
  padding-bottom: 16px;
  -webkit-overflow-scrolling: touch;
  scroll-snap-type: x proximity;
  width: 100%; box-sizing: border-box;
}
.kanban::-webkit-scrollbar { height: 4px; }
.kanban::-webkit-scrollbar-track { background: rgba(0,180,255,0.05); }
.kanban::-webkit-scrollbar-thumb { background: rgba(0,180,255,0.3); border-radius: 2px; }
.k-col {
  min-width: 240px; flex: 0 0 240px;
  background: rgba(5,11,20,0.6);
  border: 1px solid var(--border-dim);
  padding: 12px; flex-shrink: 0;
  scroll-snap-align: start;
}
.k-col-head {
  font-family: 'Orbitron', monospace;
  font-size: 9px; letter-spacing: 2px;
  margin-bottom: 12px;
  display: flex; align-items: center; justify-content: space-between;
  text-transform: uppercase;
}
.k-card {
  border: 1px solid var(--border-dim);
  background: rgba(8,15,28,0.9);
  padding: 10px; margin-bottom: 8px;
  cursor: pointer; transition: all 0.2s;
  position: relative;
}
.k-card::before {
  content: ''; position: absolute;
  left: 0; top: 0; bottom: 0; width: 2px;
}
.k-card:hover { border-color: var(--border-glow); transform: translateX(2px); }
.k-card-co { font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 13px; color: var(--text); }
.k-card-role { font-size: 11px; color: var(--text3); margin-top: 2px; font-family: 'Share Tech Mono', monospace; }

/* SECTION HEADER */
.sec-head { margin-bottom: 20px; }
.sec-id { font-family: 'Share Tech Mono', monospace; font-size: 9px; letter-spacing: 3px; color: var(--text3); margin-bottom: 4px; text-transform: uppercase; }
.sec-title { font-family: 'Orbitron', monospace; font-size: 18px; font-weight: 700; color: var(--text); letter-spacing: 1px; }
.sec-sub { font-family: 'Share Tech Mono', monospace; font-size: 10px; color: var(--text3); margin-top: 4px; letter-spacing: 1px; }

/* SPECIAL EFFECTS */
.glitch {
  position: relative;
  animation: glitch 5s infinite;
}
@keyframes glitch {
  0%,94%,100% { text-shadow: none; }
  95% { text-shadow: -2px 0 var(--aot-red2), 2px 0 var(--sl-blue); }
  96% { text-shadow: 2px 0 var(--aot-red2), -2px 0 var(--sl-blue); }
  97% { text-shadow: none; }
}

.system-notification {
  position: fixed; bottom: 20px; right: 20px; z-index: 2000;
  background: var(--panel);
  border: 1px solid var(--sl-blue);
  border-left: 3px solid var(--sl-blue);
  padding: 12px 16px; min-width: 280px;
  box-shadow: 0 0 20px var(--sl-glow);
  animation: notifIn 0.3s ease;
  font-family: 'Share Tech Mono', monospace;
}
@keyframes notifIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
.notif-header { font-size: 8px; letter-spacing: 2px; color: var(--sl-blue); margin-bottom: 4px; }
.notif-msg { font-size: 12px; color: var(--text); }

.notif-red { border-color: var(--aot-red2); border-left-color: var(--aot-red2); box-shadow: 0 0 20px var(--aot-glow); }
.notif-red .notif-header { color: var(--aot-red2); }
.notif-green { border-color: var(--success); border-left-color: var(--success); box-shadow: 0 0 20px rgba(0,255,136,0.3); }
.notif-green .notif-header { color: var(--success); }

/* WATER CUPS */
.water-grid { display: flex; gap: 6px; flex-wrap: wrap; }
.water-cup {
  width: 28px; height: 36px;
  border: 1px solid var(--border-dim);
  cursor: pointer; position: relative;
  overflow: hidden; display: flex; align-items: flex-end;
  transition: border-color 0.2s;
  transform: perspective(100px) rotateX(5deg);
}
.water-cup.filled { border-color: var(--ds-teal); }
.water-cup.filled::after { box-shadow: 0 0 8px rgba(0,229,204,0.3); }
.water-fill {
  width: 100%; background: linear-gradient(180deg, var(--ds-teal), rgba(0,229,204,0.5));
  transition: height 0.3s ease;
}

/* HABITS */
.habit-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.habit-name { font-family: 'Rajdhani', sans-serif; font-size: 12px; font-weight: 600; color: var(--text2); width: 110px; flex-shrink: 0; letter-spacing: 0.5px; }
.habit-dots { display: flex; gap: 4px; }
.habit-dot {
  width: 16px; height: 16px;
  border: 1px solid var(--border-dim);
  cursor: pointer; transition: all 0.15s;
  transform: rotate(45deg);
}
.habit-dot:hover { border-color: var(--sl-blue); }
.habit-dot.done { background: var(--sl-blue); border-color: var(--sl-blue); box-shadow: 0 0 8px var(--sl-glow); }

/* EMPTY STATE */
.empty {
  text-align: center; padding: 40px 20px;
}
.empty-icon { font-size: 36px; margin-bottom: 12px; opacity: 0.4; }
.empty-text {
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px; color: var(--text3);
  letter-spacing: 1px; line-height: 1.8;
}

/* OVERLAY */
.overlay.show { display: block; }

/* ============================================================
   MOBILE-FIRST RESPONSIVE STYLES
   Optimized for 360px–430px phone screens
   ============================================================ */


/* BOTTOM NAV BAR — shown only on mobile */
.bottom-nav {
  display: none;
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 60;
  background: rgba(3,8,16,0.97);
  border-top: 1px solid rgba(0,180,255,0.15);
  padding: 4px 0 calc(4px + env(safe-area-inset-bottom));
  backdrop-filter: blur(20px);
  box-shadow: 0 -4px 24px rgba(0,0,0,0.6);
}
.bottom-nav-items {
  display: flex; justify-content: space-around; align-items: stretch;
}
.bnav-item {
  display: flex; flex-direction: column; align-items: center; gap: 3px;
  flex: 1; padding: 7px 4px 6px; cursor: pointer;
  background: none; border: none; color: #4a5568;
  transition: all 0.2s; min-height: 52px;
  justify-content: center; position: relative;
}
.bnav-item::before {
  content: '';
  position: absolute; top: 0; left: 20%; right: 20%; height: 2px;
  background: var(--sl-blue);
  transform: scaleX(0); transition: transform 0.2s;
  border-radius: 0 0 2px 2px;
}
.bnav-item.active { color: var(--sl-blue); }
.bnav-item.active::before { transform: scaleX(1); }
.bnav-item.active .bnav-icon { 
  text-shadow: 0 0 12px var(--sl-glow);
  transform: translateY(-1px);
}
.bnav-item:active { transform: scale(0.92); }
.bnav-icon { font-size: 20px; transition: all 0.2s; }
.bnav-label {
  font-family: 'Share Tech Mono', monospace;
  font-size: 7px; letter-spacing: 1px; text-transform: uppercase;
  transition: color 0.2s;
}

/* MOBILE MORE DRAWER */
.more-drawer {
  display: none;
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 55;
  background: rgba(3,8,16,0.98);
  border-top: 2px solid var(--sl-blue);
  box-shadow: 0 -16px 48px rgba(0,180,255,0.12);
  padding: 20px 16px calc(76px + env(safe-area-inset-bottom));
  backdrop-filter: blur(20px);
  max-height: 72vh; overflow-y: auto;
  border-radius: 20px 20px 0 0;
}
.more-drawer.open { display: block; animation: drawerUp 0.28s cubic-bezier(0.34,1.56,0.64,1); }
@keyframes drawerUp {
  from { transform: translateY(100%); opacity: 0; }
  to   { transform: translateY(0);    opacity: 1; }
}

@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

.more-drawer-header {
  font-family: 'Orbitron', monospace;
  font-size: 10px; letter-spacing: 3px; color: var(--sl-blue);
  margin-bottom: 16px; padding-bottom: 12px;
  border-bottom: 1px solid var(--border-dim);
  display: flex; justify-content: space-between; align-items: center;
}
.more-drawer-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;
}
.more-drawer-item {
  display: flex; flex-direction: column; align-items: center; gap: 7px;
  padding: 14px 6px 12px;
  border: 1px solid var(--border-dim);
  border-radius: 8px;
  background: rgba(0,180,255,0.02);
  cursor: pointer; transition: all 0.18s; text-align: center;
  -webkit-tap-highlight-color: transparent;
}
.more-drawer-item:active {
  border-color: var(--sl-blue);
  background: rgba(0,180,255,0.1);
  transform: scale(0.94);
}
.more-drawer-item .mdi-icon { font-size: 24px; }
.more-drawer-item .mdi-label {
  font-family: 'Share Tech Mono', monospace;
  font-size: 7px; letter-spacing: 1px; color: var(--text3);
  text-transform: uppercase;
}

/* ============================================================
   MOBILE PORTRAIT — Full overhaul for phones
   ============================================================ */
@media (max-width: 768px) {
  /* Main takes full width, leaves room for bottom nav */
  .main { padding-bottom: 72px; }

  /* Topbar compact */
  .topbar { padding: 0 12px; height: 48px; }
  .topbar-left { gap: 8px; }
  .sys-clock { font-size: 10px; padding: 3px 7px; }
  #sysDate { display: none !important; }
  .page-name { font-size: 11px; letter-spacing: 2px; }
  .page-id { display: none; }
  /* Show bottom nav */
  .bottom-nav { display: block !important; }

  /* Page content padding */
  .page { padding: 14px 12px 84px; }

  /* Grids — 2 col on tablet, stacked on phone */
  .g4 { grid-template-columns: repeat(2, 1fr); }
  .g3 { grid-template-columns: repeat(2, 1fr); }
  .g2 { grid-template-columns: 1fr; }
  .ga { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }

  /* Cards */
  .stat-card { padding: 12px 10px; }
  .sc-value { font-size: 20px; }
  .sc-icon { font-size: 18px; }
  .sc-label { font-size: 7px; }

  /* Panels */
  .panel-body { padding: 12px; }
  .panel-head { padding: 10px 12px; }
  .panel-title { font-size: 9px; }

  /* Buttons — fat touch targets */
  .btn { min-height: 40px; padding: 8px 14px; font-size: 9px; }
  .btn-sm { min-height: 36px; padding: 6px 12px; font-size: 8px; }

  /* Modals — full width sheet */
  .modal { width: 100vw; max-width: 100vw; max-height: 90vh; border-radius: 16px 16px 0 0; position: fixed; bottom: 0; left: 0; right: 0; margin: 0; animation: modalUp 0.3s ease; }
  @keyframes modalUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
  .modal-body { padding: 16px; }
  .modal-footer { padding: 12px 16px; }

  /* Fields */
  .sys-field { font-size: 14px; padding: 10px 12px; min-height: 44px; }
  select.sys-field { min-height: 44px; }

  /* Quest items */
  .quest-check { width: 22px; height: 22px; flex-shrink: 0; }

  /* Floating elements */
  #questTimerFloat { left: 10px; right: 10px; bottom: 78px; }
  .system-notification { left: 10px; right: 10px; min-width: unset; bottom: 78px; }

  /* AI chat */
  #aiChatBtn { bottom: 82px !important; right: 12px !important; }
  #aiChatPanel { bottom: 155px !important; right: 8px !important; left: 8px !important; width: auto !important; max-height: calc(100vh - 200px) !important; }

  /* Hide decorative panel corners on mobile */
  .panel-corner { display: none; }

  /* XP header wraps */
  .xp-header-stats { flex-wrap: wrap; gap: 8px; }
  .xp-header-stat { min-width: calc(50% - 4px); flex: 1; }

  /* Task items readable */
  .task-text { font-size: 13px; }
  .task-meta { font-size: 9px; }

  /* Fitness grid */
  .workout-grid { grid-template-columns: 1fr !important; }

  /* Notes */
  .note-grid { grid-template-columns: 1fr !important; }

  /* Interviews/placements */
  .interview-grid { grid-template-columns: 1fr !important; }

  /* Hide sidebar overlay when open */}

@media (max-width: 480px) {
  /* Tightest phone layout */
  .page { padding: 10px 10px 84px; }
  .g4 { grid-template-columns: 1fr 1fr; }
  .g3 { grid-template-columns: 1fr 1fr; }
  .ga { grid-template-columns: 1fr 1fr; }

  .topbar { height: 44px; }
  .logo-sys { font-size: 14px !important; }

  /* Stat cards single row scroll on tiny phones */
  .stat-card { padding: 10px 8px; }
  .sc-value { font-size: 18px; }

  /* Two column budget/savings */
  .fbc { flex-wrap: wrap; gap: 6px; }

  /* Penalty grid */
  .penalty-grid { grid-template-columns: 1fr !important; }

  /* More drawer 3-col */
  .more-drawer-grid { grid-template-columns: repeat(3, 1fr); }

  /* Badges smaller */
  .badge { font-size: 7px; padding: 2px 5px; }
}

/* Touch tap highlight removal */
* { -webkit-tap-highlight-color: transparent; }
input, select, textarea, button { -webkit-appearance: none; }

/* Smooth scrolling */
.main, .sidebar-nav { -webkit-overflow-scrolling: touch; }

/* Safe area padding for notched phones */
.topbar { padding-top: env(safe-area-inset-top); }
.bottom-nav { padding-bottom: calc(8px + env(safe-area-inset-bottom)); }


/* ============================================================
   AI SYSTEM ASSISTANT STYLES
