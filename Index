// ── WEEKLY REPORT CARD ───────────────────────────────────────
function renderWeeklyReportCard(ins) {
  const { weekly } = ins;
  const diff = weekly.prevScore !== null ? weekly.score - weekly.prevScore : null;
  const diffText = diff===null ? '' : diff>0 ? `▲ ${diff} vs last week` : diff<0 ? `▼ ${Math.abs(diff)} vs last week` : '= same as last week';
  const diffColor = diff===null ? 'var(--text3)' : diff>0 ? '#22c55e' : diff<0 ? 'var(--aot-red2)' : 'var(--text3)';

  const scoreColor = weekly.score>=80?'#22c55e':weekly.score>=60?'#f97316':'var(--aot-red2)';

  const areas = [
    { label:'TASKS',   score:weekly.taskScore,    icon:'📋', detail:`${weekly.weekDone} completed this week` },
    { label:'FITNESS', score:weekly.fitnessScore,  icon:'💪', detail:`${weekly.weekWO}/${5} workouts` },
    { label:'FINANCE', score:weekly.financeScore,  icon:'💰', detail:`₹${fmtMoney(Math.abs(ins.finance.netBalance))} net ${ins.finance.netBalance>=0?'positive':'negative'}` },
    { label:'GOALS',   score:weekly.goalsScore,    icon:'🎯', detail:`${weekly.weekGoalsDone} goals completed` },
  ];

  return `
  <div class="panel mb12">
    <div class="panel-corner pc-tl"></div><div class="panel-corner pc-tr"></div>
    <div class="panel-head"><span class="panel-title">⟦ WEEKLY REPORT CARD ⟧</span></div>
    <div class="panel-body">
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:14px;flex-wrap:wrap">
        <div style="text-align:center">
          <div style="font-family:'Orbitron',monospace;font-size:36px;font-weight:900;color:${scoreColor};line-height:1">${weekly.score}</div>
          <div style="font-family:'Share Tech Mono',monospace;font-size:8px;color:var(--text3)">/ 100</div>
          <div style="font-family:'Share Tech Mono',monospace;font-size:8px;color:${diffColor};margin-top:3px">${diffText}</div>
        </div>
        <div style="flex:1;display:flex;flex-direction:column;gap:6px">
          ${areas.map(a=>{
            const barColor=a.score>=80?'#22c55e':a.score>=60?'#f97316':'var(--aot-red2)';
            return `<div>
              <div style="display:flex;justify-content:space-between;margin-bottom:3px">
                <span style="font-family:'Share Tech Mono',monospace;font-size:8px;color:var(--text3)">${a.icon} ${a.label}</span>
                <span style="font-family:'Orbitron',monospace;font-size:9px;color:${barColor}">${a.score}%</span>
              </div>
              <div style="height:5px;background:rgba(0,180,255,0.06);border-radius:3px">
                <div style="height:100%;width:${a.score}%;background:${barColor};border-radius:3px;transition:width 1s ease"></div>
              </div>
              <div style="font-family:'Share Tech Mono',monospace;font-size:7px;color:var(--text3);margin-top:1px">${a.detail}</div>
            </div>`;
          }).join('')}
        </div>
      </div>
    </div>
  </div>`;
}

