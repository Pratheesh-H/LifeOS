function renderAnalystReport(rawText, ctx) {
  const reportEl = document.getElementById('analystReport');
  const now = new Date();

  // Split into sections by ⟦ ... ⟧ headers
  const sections = [];
  const lines = rawText.split('\n');
  let currentSection = null;
  let currentLines = [];

  for (const line of lines) {
    const headerMatch = line.match(/⟦\s*(.+?)\s*⟧/);
    if (headerMatch) {
      if (currentSection) sections.push({ title: currentSection, body: currentLines.join('\n').trim() });
      currentSection = headerMatch[1];
      currentLines = [];
    } else {
      currentLines.push(line);
    }
  }
  if (currentSection) sections.push({ title: currentSection, body: currentLines.join('\n').trim() });

  // Section icon map
  const icons = {
    'OVERALL': '⚡', 'STATUS': '⚡', 'DAILY': '📋', 'MISSION': '🎯', 'BODY': '💪',
    'GOLD': '💰', 'VAULT': '💰', 'FINANCE': '💰', 'SKILL': '📚', 'CAREER': '⚔️',
    'INTELLIGENCE': '🧠', 'ASSESSMENT': '🧠', 'OPERATIONS': '📋', 'COMBAT': '💪',
    'DEVELOPMENT': '📚', 'BATTLEFIELD': '⚔️', 'PROGRESS': '🎯', 'ANALYSIS': '💰'
  };

  function getIcon(title) {
    const upper = title.toUpperCase();
    for (const [k,v] of Object.entries(icons)) {
      if (upper.includes(k)) return v;
    }
    return '◈';
  }

  // Color accent per section index
  const accents = ['var(--sl-blue)','#22c55e','#f97316','var(--jjk-purple2)','#ffd700','var(--ds-teal)','var(--aot-red2)','var(--sl-blue)'];

  // Stat pills from context
  const statPills = [
    { label: 'LEVEL', value: 'LV '+ctx.player.level, color: '#ffd700' },
    { label: 'STREAK', value: ctx.player.streak+'d', color: 'var(--ds-teal)' },
    { label: 'TASKS', value: ctx.tasks.completionRate+'%', color: ctx.tasks.completionRate>=80?'#22c55e':'#f97316' },
    { label: 'WORKOUTS', value: ctx.fitness.workoutsThisWeek+'/wk', color: 'var(--jjk-purple2)' },
    { label: 'NET', value: (ctx.finance.netBalance>=0?'+':'')+'₹'+fmtMoney(ctx.finance.netBalance), color: ctx.finance.netBalance>=0?'#22c55e':'var(--aot-red2)' },
    { label: 'CERTS', value: ctx.learning.certifications, color: 'var(--sl-blue)' },
  ];

  let html = `
  <!-- REPORT HEADER -->
  <div class="panel mb12" style="background:linear-gradient(135deg,rgba(0,180,255,0.06),rgba(0,0,0,0))">
    <div class="panel-corner pc-tl"></div><div class="panel-corner pc-tr"></div>
    <div class="panel-body">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:10px;margin-bottom:14px">
        <div>
          <div style="font-family:'Share Tech Mono',monospace;font-size:8px;color:var(--text3);letter-spacing:3px">// INTELLIGENCE REPORT</div>
          <div style="font-family:'Orbitron',monospace;font-size:16px;font-weight:900;color:var(--sl-blue);margin-top:4px">HUNTER ANALYSIS</div>
          <div style="font-family:'Share Tech Mono',monospace;font-size:8px;color:var(--text3);margin-top:3px">${ctx.generatedAt}</div>
        </div>
        <button class="btn btn-ghost btn-sm" onclick="renderAIAnalyst()" style="font-size:8px">↺ REFRESH</button>
      </div>
      <!-- Stat pills -->
      <div style="display:flex;flex-wrap:wrap;gap:8px">
        ${statPills.map(p=>`
          <div style="padding:6px 12px;border:1px solid ${p.color}33;background:${p.color}11;text-align:center;flex:1;min-width:70px">
            <div style="font-family:'Share Tech Mono',monospace;font-size:7px;color:var(--text3);letter-spacing:1px">${p.label}</div>
            <div style="font-family:'Orbitron',monospace;font-size:13px;font-weight:700;color:${p.color};margin-top:2px">${p.value}</div>
          </div>`).join('')}
      </div>
    </div>
  </div>`;

  // Render each section as a panel
  sections.forEach((sec, i) => {
    const accent = accents[i % accents.length];
    const icon = getIcon(sec.title);

    // Format body — look for lines starting with tactical recommendation indicators
    const bodyLines = sec.body.split('\n').filter(l => l.trim());
    let formattedBody = '';
    bodyLines.forEach(line => {
      const trimmed = line.trim();
      if (!trimmed) return;
      // Detect recommendation / action lines
      if (trimmed.match(/^(RECOMMENDATION|ACTION|PRIORITY|TACTICAL|→|▸|•|-\s)/i) ||
          trimmed.toLowerCase().startsWith('recommendation') ||
          trimmed.startsWith('→') || trimmed.startsWith('▸')) {
        formattedBody += `<div style="margin-top:10px;padding:8px 12px;background:${accent}11;border-left:2px solid ${accent};font-family:'Share Tech Mono',monospace;font-size:9px;color:${accent};line-height:1.6">${trimmed}</div>`;
      } else {
        formattedBody += `<div style="font-family:'Rajdhani',sans-serif;font-size:14px;color:var(--text2);line-height:1.6;margin-bottom:4px">${trimmed}</div>`;
      }
    });

    html += `
    <div class="panel mb10">
      <div class="panel-corner pc-tl"></div>
      <div class="panel-head" style="border-bottom:1px solid ${accent}33">
        <span style="font-family:'Orbitron',monospace;font-size:10px;font-weight:700;color:${accent};letter-spacing:2px">${icon} ⟦ ${sec.title} ⟧</span>
