    { label:'CERTIFICATIONS',value:ctx.learning.certifications + ' CERTS',  color:'#00b4ff' },
    { label:'COURSES DONE',  value:ctx.learning.completedCourses + ' DONE', color:'#22c55e' },
  ];

  // ── BUILD THE PDF HTML PAGE ──────────────────────────────────────────────────
  const sectionHTML = sections.map((sec, i) => {
    const accent = accentColors[i % accentColors.length];
    const icon   = getIcon(sec.title);
    const keyPts = extractKeyPoints(sec.body);
    const rec    = extractRecommendation(sec.body);
    const fullBody = sec.body.split('\n').filter(l=>l.trim()).map(l => {
      const t = l.trim();
