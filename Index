function saveTask(eid) {
  const text = document.getElementById('tText').value.trim();
  if (!text) { showNotif('MISSION OBJECTIVE REQUIRED', 'red'); return; }
  const tasks = Store.get('dailyTasks', []);
  const pri = document.getElementById('tPri').value;
  const notifTime = document.getElementById('tNotif').value;
  const nt = {
    id: eid || uid(), text, priority: pri,
    questType: document.getElementById('tQType').value,
    category: document.getElementById('tCat').value.trim(),
    deadline: document.getElementById('tDead').value,
    estimatedTime: document.getElementById('tEstTime').value,
    notifTime,
    notes: document.getElementById('tNote').value.trim(),
    date: today(), done: false
  };
  if (eid) { const i = tasks.findIndex(t => t.id === eid); if (i > -1) { nt.done = tasks[i].done; tasks[i] = nt; } }
  else tasks.push(nt);
  Store.set('dailyTasks', tasks);
  closeModal();
  showNotif(`⚔️ QUEST ACCEPTED — +${XP_TABLE[pri]} XP on completion`, 'green');
  // Schedule notification if set
  if (notifTime && Store.get('notifEnabled', false)) scheduleQuestNotif(nt);
  renderDaily();
}

function toggleTask(id) {
  const tasks = Store.get('dailyTasks', []);
  const t = tasks.find(t => t.id === id);
  if (!t) return;
  t.done = !t.done;
  Store.set('dailyTasks', tasks);
  if (t.done) {
    const streakBonus = Math.min((getPlayerData().streak || 0) * 2, 30);
    const xp = XP_TABLE[t.priority || 'low'];
    const bonusXP = Math.round(xp * streakBonus / 100);
    addXP(xp + bonusXP);
    addAura(AURA_TABLE[t.priority || 'low']);
    updateStreak();
    const msg = bonusXP > 0 ? `+${xp}+${bonusXP} BONUS XP — AURA INCREASED` : `+${xp} XP GAINED`;
    showNotif(`✅ QUEST CLEARED — ${msg}`, 'green');
    sendBrowserNotif('QUEST CLEARED!', `${t.text} — +${xp + bonusXP} XP earned!`, '✅');
    // Check if all done
    const allTasks = Store.get('dailyTasks', []).filter(t2 => t2.date === today());
    if (allTasks.every(t2 => t2.done)) {
      setTimeout(() => {
        showNotif('🏆 PERFECT DAY ACHIEVED — ALL QUESTS CLEARED!', 'green');
        sendBrowserNotif('PERFECT DAY! 🏆', 'All daily quests cleared! Bonus XP rewarded!', '🌟');
        addXP(100); addAura(50);
      }, 800);
    }
  } else {
    showNotif('↩ QUEST REACTIVATED — XP PENDING', 'default');
  }
  if (currentPage === 'daily') renderDaily();
}

function delTask(id) {
  Store.set('dailyTasks', Store.get('dailyTasks', []).filter(t => t.id !== id));
  showNotif('⚠ QUEST ABANDONED');
  if (currentPage === 'daily') renderDaily();
}
function clearDoneTasks() {
  Store.set('dailyTasks', Store.get('dailyTasks', []).filter(t => !(t.done && t.date === today())));
  renderDaily();
}

