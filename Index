function renderFinance() {
  const el = document.getElementById('pageContent');
  const txns = Store.get('financeTxns', []);
  const budgets = Store.get('financeBudgets', []);
  const savingsGoals = Store.get('financeSavings', []);
  const now = new Date();
  const thisMonth = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
  const monthTxns  = txns.filter(t => t.date && t.date.startsWith(thisMonth));
  const totalIncome  = monthTxns.filter(t=>t.type==='income').reduce((s,t)=>s+t.amount,0);
  const totalExpense = monthTxns.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const netBalance   = totalIncome - totalExpense;
  const allTimeBalance = txns.filter(t=>t.type==='income').reduce((s,t)=>s+t.amount,0)
                       - txns.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);

  // ── CATEGORY DONUT DATA ──
  const expTxns = monthTxns.filter(t=>t.type==='expense');
  const catMap = {};
  expTxns.forEach(t=>{ catMap[t.category]=(catMap[t.category]||0)+t.amount; });
  const catEntries = Object.entries(catMap).sort((a,b)=>b[1]-a[1]);

  // ── 6-MONTH BARS ──
  const months6 = [];
  for (let i=5;i>=0;i--) {
    const d=new Date(); d.setMonth(d.getMonth()-i);
    const key=`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
    const lbl=d.toLocaleString('en-IN',{month:'short'}).toUpperCase();
    months6.push({
      key, lbl,
      inc: txns.filter(t=>t.type==='income'  &&t.date?.startsWith(key)).reduce((s,t)=>s+t.amount,0),
      exp: txns.filter(t=>t.type==='expense' &&t.date?.startsWith(key)).reduce((s,t)=>s+t.amount,0)
    });
  }
  const maxBar = Math.max(...months6.map(m=>Math.max(m.inc,m.exp)),1);

  // ── DONUT SVG ──
  function donutSVG(entries, total, cx, label, valLabel, col2) {
    if (!total) return `<div class="empty"><div class="empty-icon">📊</div><div class="empty-text" style="font-size:10px">NO DATA YET</div></div>`;
    let paths='', cum=-90;
    entries.slice(0,7).forEach(([cat,val])=>{
      const angle=(val/total)*360, r2d=Math.PI/180, R=45, IR=28;
      const x1=cx+R*Math.cos(cum*r2d), y1=cx+R*Math.sin(cum*r2d);
      const x2=cx+R*Math.cos((cum+angle)*r2d), y2=cx+R*Math.sin((cum+angle)*r2d);
      const xi1=cx+IR*Math.cos(cum*r2d), yi1=cx+IR*Math.sin(cum*r2d);
      const xi2=cx+IR*Math.cos((cum+angle)*r2d), yi2=cx+IR*Math.sin((cum+angle)*r2d);
      const lg=angle>180?1:0, col=CAT_COLORS[cat]||'#6b7280';
      paths+=`<path d="M${x1.toFixed(1)},${y1.toFixed(1)} A${R},${R} 0 ${lg},1 ${x2.toFixed(1)},${y2.toFixed(1)} L${xi2.toFixed(1)},${yi2.toFixed(1)} A${IR},${IR} 0 ${lg},0 ${xi1.toFixed(1)},${yi1.toFixed(1)} Z" fill="${col}" stroke="#020810" stroke-width="1.5" opacity="0.9"/>`;
      cum+=angle;
    });
    return `<svg viewBox="0 0 120 120" width="120" height="120" style="overflow:visible">${paths}
      <text x="${cx}" y="${cx-4}" text-anchor="middle" font-family="Orbitron,monospace" font-size="8" fill="#c8e8ff">${label}</text>
      <text x="${cx}" y="${cx+8}" text-anchor="middle" font-family="Orbitron,monospace" font-size="10" font-weight="bold" fill="${col2||'#00b4ff'}">${valLabel}</text>
    </svg>`;
  }

  // ── SORTED TRANSACTIONS (latest 8 for feed) ──
  const recentTxns = [...txns].sort((a,b)=>(b.date||'').localeCompare(a.date||'')).slice(0,8);

  el.innerHTML = `
  <!-- HEADER -->
  <div style="margin-bottom:16px">
    <div style="font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:3px;color:var(--text3)">// FINANCIAL OPERATIONS MODULE</div>
    <div style="font-family:'Orbitron',monospace;font-size:20px;font-weight:900;color:var(--text);letter-spacing:1px;margin-top:4px">GOLD VAULT</div>
  </div>

  <!-- STAT CARDS -->
  <div class="g g4 mb12">
    <div class="stat-card sc-teal"><div class="sc-icon">💰</div><div class="sc-label">// INCOME</div><div class="sc-value">₹${fmtMoney(totalIncome)}</div></div>
    <div class="stat-card sc-red"><div class="sc-icon">💸</div><div class="sc-label">// SPENT</div><div class="sc-value">₹${fmtMoney(totalExpense)}</div></div>
    <div class="stat-card ${netBalance>=0?'sc-blue':'sc-orange'}"><div class="sc-icon">${netBalance>=0?'📈':'📉'}</div><div class="sc-label">// NET</div><div class="sc-value" style="color:${netBalance>=0?'var(--success)':'var(--aot-red2)'}">₹${fmtMoney(Math.abs(netBalance))}</div></div>
    <div class="stat-card sc-purple"><div class="sc-icon">🏦</div><div class="sc-label">// ALL TIME</div><div class="sc-value" style="color:${allTimeBalance>=0?'var(--success)':'var(--aot-red2)'}">₹${fmtMoney(allTimeBalance)}</div></div>
  </div>

  <!-- QUICK ADD -->
  <div style="display:flex;gap:8px;margin-bottom:16px">
    <button class="btn btn-teal btn-sm" style="flex:1" onclick="openAddTxn('income')">+ ADD INCOME</button>
    <button class="btn btn-red btn-sm" style="flex:1" onclick="openAddTxn('expense')">- ADD EXPENSE</button>
  </div>

  <!-- CHARTS ROW -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px">
    <!-- Spending Donut -->
    <div class="panel">
      <div class="panel-corner pc-tl"></div><div class="panel-corner pc-tr"></div>
      <div class="panel-head"><span class="panel-title">⟦ SPENDING BY CATEGORY ⟧</span></div>
      <div class="panel-body" style="display:flex;flex-direction:column;align-items:center;gap:8px">
        ${donutSVG(catEntries, catEntries.reduce((s,[,v])=>s+v,0)||0, 60, 'SPENT', '₹'+fmtMoney(totalExpense), '#ef4444')}
        <div style="width:100%;display:flex;flex-direction:column;gap:3px">
          ${catEntries.slice(0,5).map(([cat,val])=>`
            <div style="display:flex;align-items:center;justify-content:space-between">
              <div style="display:flex;align-items:center;gap:5px">
                <div style="width:7px;height:7px;border-radius:2px;background:${CAT_COLORS[cat]||'#6b7280'}"></div>
                <span style="font-family:'Share Tech Mono',monospace;font-size:8px;color:var(--text3)">${cat.toUpperCase()}</span>
              </div>
              <span style="font-family:'Orbitron',monospace;font-size:9px;color:var(--text)">₹${fmtMoney(val)}</span>
            </div>`).join('')}
        </div>
      </div>
    </div>
    <!-- Income vs Expense Donut -->
    <div class="panel">
      <div class="panel-corner pc-tl"></div><div class="panel-corner pc-tr"></div>
      <div class="panel-head"><span class="panel-title">⟦ INCOME vs EXPENSE ⟧</span></div>
      <div class="panel-body" style="display:flex;flex-direction:column;align-items:center;gap:8px">
        ${donutSVG([['Income',totalIncome],['Expense',totalExpense]].filter(e=>e[1]>0),
          totalIncome+totalExpense, 60, 'BALANCE',
          (netBalance>=0?'+':'-')+'₹'+fmtMoney(Math.abs(netBalance)),
          netBalance>=0?'#22c55e':'#ef4444')}
        <div style="display:flex;gap:14px">
          <div style="text-align:center">
            <div style="display:flex;align-items:center;gap:4px"><div style="width:7px;height:7px;background:#22c55e;border-radius:2px"></div><span style="font-family:'Share Tech Mono',monospace;font-size:8px;color:var(--text3)">INCOME</span></div>
            <div style="font-family:'Orbitron',monospace;font-size:10px;color:#22c55e">₹${fmtMoney(totalIncome)}</div>
          </div>
          <div style="text-align:center">
            <div style="display:flex;align-items:center;gap:4px"><div style="width:7px;height:7px;background:#ef4444;border-radius:2px"></div><span style="font-family:'Share Tech Mono',monospace;font-size:8px;color:var(--text3)">EXPENSE</span></div>
            <div style="font-family:'Orbitron',monospace;font-size:10px;color:#ef4444">₹${fmtMoney(totalExpense)}</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 6-MONTH BAR CHART -->
  <div class="panel mb12">
    <div class="panel-corner pc-tl"></div><div class="panel-corner pc-tr"></div>
    <div class="panel-head fbc">
      <span class="panel-title">⟦ 6-MONTH OVERVIEW ⟧</span>
      <div style="display:flex;gap:10px">
        <span style="font-family:'Share Tech Mono',monospace;font-size:8px;color:#22c55e">▮ INCOME</span>
        <span style="font-family:'Share Tech Mono',monospace;font-size:8px;color:#ef4444">▮ EXPENSE</span>
      </div>
    </div>
    <div class="panel-body">
      <div style="display:flex;align-items:flex-end;justify-content:space-around;gap:4px;height:110px;padding-top:18px">
        ${months6.map(m=>{
          const ih=Math.round((m.inc/maxBar)*90), eh=Math.round((m.exp/maxBar)*90);
          return `<div style="display:flex;flex-direction:column;align-items:center;gap:3px;flex:1">
            <div style="display:flex;align-items:flex-end;gap:2px;height:90px">
              <div style="width:10px;height:${ih||2}px;background:linear-gradient(0deg,#16a34a,#4ade80);border-radius:2px 2px 0 0;position:relative">
                ${m.inc?`<div style="position:absolute;top:-13px;left:50%;transform:translateX(-50%);font-family:'Share Tech Mono',monospace;font-size:7px;color:#4ade80;white-space:nowrap">${fmtMoney(m.inc)}</div>`:''}
              </div>
              <div style="width:10px;height:${eh||2}px;background:linear-gradient(0deg,#b91c1c,#ef4444);border-radius:2px 2px 0 0;position:relative">
                ${m.exp?`<div style="position:absolute;top:-13px;left:50%;transform:translateX(-50%);font-family:'Share Tech Mono',monospace;font-size:7px;color:#ef4444;white-space:nowrap">${fmtMoney(m.exp)}</div>`:''}
              </div>
            </div>
            <span style="font-family:'Share Tech Mono',monospace;font-size:8px;color:var(--text3)">${m.lbl}</span>
          </div>`;
        }).join('')}
      </div>
    </div>
  </div>

  <!-- BUDGET TRACKER -->
  <div class="panel mb12">
    <div class="panel-corner pc-tl"></div><div class="panel-corner pc-tr"></div>
    <div class="panel-head fbc">
      <span class="panel-title">⟦ BUDGET LIMITS ⟧</span>
      <button class="btn btn-blue btn-sm" onclick="openAddBudget()">+ ADD</button>
    </div>
    <div class="panel-body" style="display:flex;flex-direction:column;gap:10px">
      ${budgets.length ? budgets.map(b=>{
        const spent=expTxns.filter(t=>t.category===b.category).reduce((s,t)=>s+t.amount,0);
        const pct=Math.min(Math.round((spent/b.limit)*100),100);
        const over=spent>b.limit;
        const barCol=pct>=90?'#ef4444':pct>=70?'#f97316':'#22c55e';
        return `<div>
          <div class="fbc mb4">
            <div style="display:flex;align-items:center;gap:6px">
              <span style="font-size:14px">${getCatEmoji(b.category)}</span>
              <span style="font-family:'Orbitron',monospace;font-size:10px;color:var(--text)">${b.category.toUpperCase()}</span>
            </div>
            <div style="display:flex;align-items:center;gap:8px">
              <span style="font-family:'Share Tech Mono',monospace;font-size:9px;color:${over?'#ef4444':'var(--text3)'}">
                ${over?'⚠ OVER':'₹'+fmtMoney(b.limit-spent)+' LEFT'}
              </span>
              <span style="font-family:'Orbitron',monospace;font-size:11px;color:${over?'#ef4444':'var(--text)'}">₹${fmtMoney(spent)} / ₹${fmtMoney(b.limit)}</span>
              <button onclick="delBudget('${b.id}')" style="font-size:9px;padding:2px 5px;border:1px solid rgba(255,68,68,0.3);color:var(--aot-red2);background:transparent;cursor:pointer">✕</button>
            </div>
          </div>
          <div style="height:7px;background:rgba(0,180,255,0.06);border:1px solid var(--border-dim);overflow:hidden;border-radius:4px">
            <div style="height:100%;width:${pct}%;background:${barCol};border-radius:4px;transition:width 0.8s ease"></div>
          </div>
        </div>`;
      }).join('') : `<div class="empty" style="padding:12px 0"><div class="empty-icon" style="font-size:24px">🎯</div><div class="empty-text">NO BUDGETS SET</div></div>`}
    </div>
  </div>

  <!-- SAVINGS GOALS -->
  ${savingsGoals.length ? `
  <div class="panel mb12">
    <div class="panel-corner pc-tl"></div><div class="panel-corner pc-tr"></div>
    <div class="panel-head fbc">
      <span class="panel-title">⟦ SAVINGS GOALS ⟧</span>
      <button class="btn btn-blue btn-sm" onclick="openAddSavings()">+ ADD</button>
    </div>
    <div class="panel-body" style="display:flex;flex-direction:column;gap:10px">
      ${savingsGoals.map(g=>{
        const pct=Math.min(Math.round((g.saved/g.target)*100),100);
        const done=g.saved>=g.target;
        return `<div>
          <div class="fbc mb4">
            <span style="font-family:'Orbitron',monospace;font-size:11px;color:var(--text)">${g.name.toUpperCase()}</span>
            <div style="display:flex;align-items:center;gap:8px">
              <span style="font-family:'Share Tech Mono',monospace;font-size:9px;color:var(--text3)">₹${fmtMoney(g.saved)} / ₹${fmtMoney(g.target)}</span>
              <span style="font-family:'Orbitron',monospace;font-size:12px;font-weight:700;color:${done?'#22c55e':'var(--sl-blue)'}">${pct}%</span>
              <button onclick="openAddDeposit('${g.id}')" style="font-size:8px;padding:2px 7px;border:1px solid var(--sl-blue);color:var(--sl-blue);background:rgba(0,180,255,0.06);cursor:pointer">+</button>
              <button onclick="delSavings('${g.id}')" style="font-size:9px;padding:2px 5px;border:1px solid rgba(255,68,68,0.3);color:var(--aot-red2);background:transparent;cursor:pointer">✕</button>
            </div>
          </div>
          <div style="height:8px;background:rgba(0,180,255,0.06);border:1px solid var(--border-dim);overflow:hidden;border-radius:4px">
            <div style="height:100%;width:${pct}%;background:${done?'linear-gradient(90deg,#16a34a,#4ade80)':'linear-gradient(90deg,var(--sl-blue2),var(--sl-blue))'};border-radius:4px;transition:width 1s ease"></div>
          </div>
          ${done?`<div style="font-family:'Orbitron',monospace;font-size:8px;letter-spacing:2px;color:#22c55e;margin-top:4px">🏆 GOAL ACHIEVED!</div>`:''}
        </div>`;
      }).join('')}
    </div>
  </div>` : `<div class="empty" style="padding:12px 0"><div class="empty-icon" style="font-size:24px">💎</div><div class="empty-text">NO SAVINGS GOALS</div></div>`}
    </div>
  </div>

  <!-- TRANSACTION FEED -->
  <div class="panel mb12">
    <div class="panel-corner pc-tl"></div><div class="panel-corner pc-tr"></div>
    <div class="panel-head fbc">
      <span class="panel-title">⟦ RECENT TRANSACTIONS ⟧</span>
    </div>
    <div class="panel-body" style="padding:0">
      ${recentTxns.length===0 ? `<div class="empty" style="padding:20px"><div class="empty-icon">💸</div><div class="empty-text">NO TRANSACTIONS YET</div></div>` :
        recentTxns.map(t=>`
        <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid var(--border-dim)">
          <div style="width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;background:${t.type==='income'?'rgba(34,197,94,0.1)':'rgba(239,68,68,0.1)'};border:1px solid ${t.type==='income'?'rgba(34,197,94,0.3)':'rgba(239,68,68,0.3)'}">
            ${getCatEmoji(t.category)}
          </div>
          <div style="flex:1;min-width:0">
            <div style="font-family:'Rajdhani',sans-serif;font-size:13px;font-weight:600;color:var(--text)">${t.desc||t.category}</div>
            <div style="display:flex;gap:6px;align-items:center;margin-top:1px">
              <span class="badge ${t.type==='income'?'b-teal':'b-red'}" style="font-size:7px">${t.category?.toUpperCase()}</span>
              <span style="font-family:'Share Tech Mono',monospace;font-size:8px;color:var(--text3)">${fdate(t.date)}</span>
            </div>
          </div>
          <div style="text-align:right;flex-shrink:0">
            <div style="font-family:'Orbitron',monospace;font-size:13px;font-weight:700;color:${t.type==='income'?'#22c55e':'#ef4444'}">${t.type==='income'?'+':'-'}₹${fmtMoney(t.amount)}</div>
            <button onclick="delTxn('${t.id}')" style="font-family:'Share Tech Mono',monospace;font-size:7px;padding:2px 5px;border:1px solid rgba(255,68,68,0.3);color:var(--aot-red2);background:transparent;cursor:pointer;margin-top:2px">DEL</button>
          </div>
        </div>`).join('')}
    </div>
  </div>`;
}

// ── MODALS ──────────────────────────────────────────────────────────────────
function openAddTxn(type='expense') {
  const cats = type==='income' ? INCOME_CATS : EXPENSE_CATS;
  openModal(`
    <div class="modal-header">
      <span class="modal-title">⟦ ADD ${type.toUpperCase()} ⟧</span>
      <button class="btn btn-ghost btn-xs" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="field-group"><label class="field-label">// AMOUNT (₹) *</label>
        <input type="number" class="sys-field" id="txnAmount" placeholder="0.00" min="0" step="0.01"/>
      </div>
      <div class="g g2 gap8">
        <div class="field-group"><label class="field-label">// CATEGORY</label>
          <select class="sys-field" id="txnCat">${cats.map(c=>`<option value="${c}">${c.toUpperCase()}</option>`).join('')}</select>
        </div>
        <div class="field-group"><label class="field-label">// DATE</label>
          <input type="date" class="sys-field" id="txnDate" value="${today()}"/>
        </div>
      </div>
      <div class="field-group"><label class="field-label">// DESCRIPTION</label>
        <input class="sys-field" id="txnDesc" placeholder="e.g. Groceries at D-Mart..."/>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal()">ABORT</button>
      <button class="btn ${type==='income'?'btn-teal':'btn-red'}" onclick="saveTxn('${type}')">LOG ${type.toUpperCase()}</button>
    </div>`);
}

function saveTxn(type) {
  const amount = parseFloat(document.getElementById('txnAmount').value);
  if (!amount||amount<=0) { showNotif('ENTER A VALID AMOUNT','red'); return; }
  const txns = Store.get('financeTxns',[]);
  txns.push({ id:uid(), type, amount,
    category: document.getElementById('txnCat').value,
    date: document.getElementById('txnDate').value,
    desc: document.getElementById('txnDesc').value.trim() });
  Store.set('financeTxns', txns);
  closeModal(); showNotif(`${type==='income'?'💰 INCOME':'💸 EXPENSE'} LOGGED — ₹${fmtMoney(amount)}`,'green');
  renderFinance();
}

function delTxn(id) {
  Store.set('financeTxns', Store.get('financeTxns',[]).filter(t=>t.id!==id));
  showNotif('TRANSACTION REMOVED'); renderFinance();
}

function openAddBudget() {
  openModal(`
    <div class="modal-header"><span class="modal-title">⟦ SET BUDGET LIMIT ⟧</span><button class="btn btn-ghost btn-xs" onclick="closeModal()">✕</button></div>
    <div class="modal-body">
      <div class="field-group"><label class="field-label">// CATEGORY</label>
        <select class="sys-field" id="budgetCat">${EXPENSE_CATS.map(c=>`<option value="${c}">${getCatEmoji(c)} ${c.toUpperCase()}</option>`).join('')}</select>
      </div>
      <div class="field-group"><label class="field-label">// MONTHLY LIMIT (₹) *</label>
        <input type="number" class="sys-field" id="budgetLimit" placeholder="5000" min="0"/>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal()">ABORT</button>
      <button class="btn btn-blue" onclick="saveBudget()">SET LIMIT ⟶</button>
    </div>`);
}

function saveBudget() {
  const limit = parseFloat(document.getElementById('budgetLimit').value);
  if (!limit||limit<=0) { showNotif('ENTER A VALID LIMIT','red'); return; }
  const budgets = Store.get('financeBudgets',[]);
  const cat = document.getElementById('budgetCat').value;
  const existing = budgets.findIndex(b=>b.category===cat);
  const entry = { id:uid(), category:cat, limit };
  if (existing>-1) budgets[existing]=entry; else budgets.push(entry);
  Store.set('financeBudgets', budgets);
  closeModal(); showNotif(`🎯 BUDGET SET: ₹${fmtMoney(limit)} for ${cat}`,'green'); renderFinance();
}

function delBudget(id) {
  Store.set('financeBudgets', Store.get('financeBudgets',[]).filter(b=>b.id!==id));
  showNotif('BUDGET REMOVED'); renderFinance();
}

function openAddSavings() {
  openModal(`
    <div class="modal-header"><span class="modal-title">⟦ NEW SAVINGS GOAL ⟧</span><button class="btn btn-ghost btn-xs" onclick="closeModal()">✕</button></div>
    <div class="modal-body">
      <div class="field-group"><label class="field-label">// GOAL NAME *</label>
        <input class="sys-field" id="savName" placeholder="e.g. New Laptop, Emergency Fund..."/>
      </div>
      <div class="g g2 gap8">
        <div class="field-group"><label class="field-label">// TARGET (₹) *</label>
          <input type="number" class="sys-field" id="savTarget" placeholder="50000"/>
        </div>
        <div class="field-group"><label class="field-label">// ALREADY SAVED (₹)</label>
          <input type="number" class="sys-field" id="savSaved" placeholder="0"/>
        </div>
      </div>
      <div class="field-group"><label class="field-label">// TARGET DATE</label>
        <input type="date" class="sys-field" id="savDeadline"/>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal()">ABORT</button>
      <button class="btn btn-blue" onclick="saveSavingsGoal()">CREATE GOAL ⟶</button>
    </div>`);
}

function saveSavingsGoal() {
  const name = document.getElementById('savName').value.trim();
  const target = parseFloat(document.getElementById('savTarget').value);
  if (!name||!target) { showNotif('NAME AND TARGET REQUIRED','red'); return; }
  const goals = Store.get('financeSavings',[]);
  goals.push({ id:uid(), name, target, saved:parseFloat(document.getElementById('savSaved').value)||0, deadline:document.getElementById('savDeadline').value });
  Store.set('financeSavings', goals);
  closeModal(); showNotif('💎 SAVINGS GOAL CREATED','green'); renderFinance();
}

