      <button class="btn btn-ghost btn-sm" onclick="renderAIAnalyst()">✕ CLOSE</button>
    </div>
  </div>`;

  // Store current report data for PDF download
  window._lastAnalystReport = { text: rawText, ctx: ctx };

  reportEl.innerHTML = html;
  window.scrollTo(0,0);
}


