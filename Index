// ============================================================
// INTELLIGENCE ENGINE — computes all insights from raw data
// ============================================================

function computeInsights() {
  const now        = new Date();
  const todayStr   = today();
  const thisMonth  = todayStr.slice(0,7);
  const weekAgo    = new Date(now - 7*864e5);

  // ── RAW DATA ───────────────────────────────────────────────
  const allTasks    = Store.get('dailyTasks',[]);
  const workouts    = Store.get('workouts',[]);
  const txns        = Store.get('financeTxns',[]);
  const budgets     = Store.get('financeBudgets',[]);
  const savings     = Store.get('financeSavings',[]);
  const courses     = Store.get('courses',[]);
  const monthGoals  = Store.get('monthlyGoals',[]);
  const yearGoals   = Store.get('yearlyGoals',[]);
  const player      = Store.get('playerData',{xp:0,level:1,streak:0});

  // ── TASK METRICS ───────────────────────────────────────────
  const todayTasks  = allTasks.filter(t=>t.date===todayStr);
  const doneTodayN  = todayTasks.filter(t=>t.done).length;
  const taskRate    = todayTasks.length ? Math.round(doneTodayN/todayTasks.length*100) : 0;
  const highPending = todayTasks.filter(t=>!t.done&&t.priority==='high');

  // Procrastination: tasks deferred (same text appears on >1 dates, not done)
  const textCount={};
  allTasks.filter(t=>!t.done).forEach(t=>{
    const k=(t.text||'').trim().toLowerCase();
    if(k) textCount[k]=(textCount[k]||0)+1;
  });
  const procrastinated = Object.entries(textCount).filter(([,n])=>n>=2).map(([k])=>k);

  // Last 7 days completion rates
  const last7Rates = Array.from({length:7}).map((_,i)=>{
    const d=new Date(); d.setDate(d.getDate()-6+i);
    const k=d.toISOString().split('T')[0];
    const dt=allTasks.filter(t=>t.date===k);
    return { date:k, label:d.toLocaleDateString('en',{weekday:'short'}).toUpperCase(),
             rate: dt.length ? Math.round(dt.filter(t=>t.done).length/dt.length*100) : null };
  });
  const avgRate7 = (()=>{
    const valid=last7Rates.filter(r=>r.rate!==null);
    return valid.length ? Math.round(valid.reduce((s,r)=>s+r.rate,0)/valid.length) : 0;
  })();

  // Day-of-week performance (all time)
  const dayPerf = Array.from({length:7}).map((_,i)=>{
    const dayTasks = allTasks.filter(t=>{
      if(!t.date) return false;
      return new Date(t.date).getDay()===i;
    });
    const done = dayTasks.filter(t=>t.done).length;
    return { day:['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][i],
             rate: dayTasks.length ? Math.round(done/dayTasks.length*100) : null,
             count: dayTasks.length };
  });
  const worstDay = dayPerf.filter(d=>d.rate!==null&&d.count>=3).sort((a,b)=>a.rate-b.rate)[0];
  const bestDay  = dayPerf.filter(d=>d.rate!==null&&d.count>=3).sort((a,b)=>b.rate-a.rate)[0];

  // Velocity: average tasks completed per day (last 14 days)
  const last14 = Array.from({length:14}).map((_,i)=>{
    const d=new Date(); d.setDate(d.getDate()-13+i);
    return d.toISOString().split('T')[0];
  });
  const avgDailyCompleted = (()=>{
    const counts=last14.map(k=>allTasks.filter(t=>t.date===k&&t.done).length);
    return (counts.reduce((a,b)=>a+b,0)/14).toFixed(1);
  })();
  const pendingAll = allTasks.filter(t=>!t.done&&t.date<=todayStr).length;
  const backlogDays = avgDailyCompleted>0 ? Math.ceil(pendingAll/avgDailyCompleted) : null;

  // Upcoming deadlines (next 48h)
  const soon = allTasks.filter(t=>{
    if(t.done||!t.deadline) return false;
    const dl=new Date(t.deadline);
    return dl>=now && dl<=new Date(now.getTime()+48*3600e3);
  });

  // ── FITNESS METRICS ────────────────────────────────────────
  const thisWeekWO = workouts.filter(w=>new Date(w.date)>=weekAgo);
  const totalWO    = workouts.length;
  const waterToday = Store.get('waterToday_'+todayStr,0);

  // Weekly targets (assume 5)
  const WO_TARGET  = 5;
  const woRate     = Math.round(thisWeekWO.length/WO_TARGET*100);

  // Workout streak
  let woStreak=0;
  for(let i=0;i<30;i++){
    const d=new Date(); d.setDate(d.getDate()-i);
    const k=d.toISOString().split('T')[0];
    if(workouts.some(w=>w.date===k)) woStreak++;
    else if(i>0) break;
  }

  // Last 8 weeks workout counts for heatmap
  const last8wk = Array.from({length:8}).map((_,i)=>{
    const wkStart=new Date(); wkStart.setDate(wkStart.getDate()-((7-wkStart.getDay())%7)-7*i);
    const wkEnd=new Date(wkStart); wkEnd.setDate(wkStart.getDate()+6);
    const count=workouts.filter(w=>{
      const d=new Date(w.date);
      return d>=new Date(wkStart.toISOString().split('T')[0]) &&
             d<=new Date(wkEnd.toISOString().split('T')[0]);
    }).length;
    const wkLabel=wkStart.toLocaleDateString('en',{month:'short',day:'numeric'});
    return { label:wkLabel, count, wkStart };
  }).reverse();

  // Progressive overload: last exercise repeated
  const exerciseSets = {};
  workouts.forEach(w=>{
    (w.exercises||[]).forEach(ex=>{
      const k=(ex.name||'').toLowerCase();
      if(!k) return;
      if(!exerciseSets[k]) exerciseSets[k]=[];
      exerciseSets[k].push({ date:w.date, weight:parseFloat(ex.weight||0), reps:parseInt(ex.reps||0), sets:parseInt(ex.sets||0) });
    });
  });
  const overloadTips = Object.entries(exerciseSets)
    .map(([name,sets])=>{
      const sorted=sets.sort((a,b)=>a.date.localeCompare(b.date));
      const last3=sorted.slice(-3);
      if(last3.length<3) return null;
      const sameWeight=last3.every(s=>s.weight===last3[0].weight&&s.weight>0);
      const sameReps  =last3.every(s=>s.reps===last3[0].reps&&s.reps>0);
      if(sameWeight&&sameReps)
        return { name, weight:last3[0].weight, reps:last3[0].reps,
                 suggested: Math.round((last3[0].weight*1.05)*2)/2 };
      return null;
    }).filter(Boolean).slice(0,3);

  // Body weight trend
  const fitnessData = Store.get('fitnessData',{});
  const weightLog = (fitnessData.weightLog||[]).sort((a,b)=>a.date.localeCompare(b.date));
  let weightTrend = null;
  if(weightLog.length>=3){
    const first=weightLog[0].weight, last=weightLog[weightLog.length-1].weight;
    const days=Math.max(1,(new Date(weightLog[weightLog.length-1].date)-new Date(weightLog[0].date))/864e5);
    const perWeek=((last-first)/days*7).toFixed(2);
    weightTrend={ direction: last<first?'down':last>first?'up':'flat',
                  perWeek:Math.abs(perWeek), current:last,
                  target:fitnessData.targetWeight||null };
  }

  // Task vs workout correlation
  const taskWoCorr = (()=>{
    const woWeeks={}; const taskWeeks={};
    workouts.forEach(w=>{
      const wk=getWeekKey(new Date(w.date));
      woWeeks[wk]=(woWeeks[wk]||0)+1;
    });
    allTasks.filter(t=>t.done).forEach(t=>{
      const wk=getWeekKey(new Date(t.date||todayStr));
      taskWeeks[wk]=(taskWeeks[wk]||0)+1;
    });
    const weeks=Object.keys(woWeeks).filter(k=>taskWeeks[k]!==undefined);
    if(weeks.length<4) return null;
    const highWO=weeks.filter(w=>woWeeks[w]>=4);
    const lowWO =weeks.filter(w=>woWeeks[w]<=2);
    if(!highWO.length||!lowWO.length) return null;
    const avgTaskHigh=Math.round(highWO.reduce((s,w)=>s+taskWeeks[w],0)/highWO.length);
    const avgTaskLow =Math.round(lowWO.reduce((s,w)=>s+taskWeeks[w],0)/lowWO.length);
    return avgTaskHigh>avgTaskLow ? { diff:avgTaskHigh-avgTaskLow, high:avgTaskHigh, low:avgTaskLow } : null;
  })();

  // ── FINANCE METRICS ────────────────────────────────────────
  const monthTxns   = txns.filter(t=>t.date&&t.date.startsWith(thisMonth));
  const totalIncome = monthTxns.filter(t=>t.type==='income').reduce((s,t)=>s+t.amount,0);
  const totalExp    = monthTxns.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);

  // Spending velocity per category
  const daysInMonth = new Date(now.getFullYear(),now.getMonth()+1,0).getDate();
  const dayOfMonth  = now.getDate();
  const monthPct    = dayOfMonth/daysInMonth;

  const budgetAlerts = budgets.map(b=>{
    const spent=monthTxns.filter(t=>t.type==='expense'&&t.category===b.category).reduce((s,t)=>s+t.amount,0);
    const pct=spent/b.limit;
    const projectedEnd=monthPct>0 ? spent/monthPct : spent;
    const projectedOverspend=projectedEnd-b.limit;
    return { category:b.category, spent, limit:b.limit, pct:Math.round(pct*100),
             projectedOverspend: projectedOverspend>0 ? Math.round(projectedOverspend) : null };
  }).filter(b=>b.pct>=70).sort((a,b)=>b.pct-a.pct);

  // Savings runway
  const savingsRunway = savings.map(g=>{
    const remaining=g.target-(g.saved||0);
    const monthlyDeposits=txns.filter(t=>t.type==='income'&&t.date&&t.date.startsWith(thisMonth)).length;
    // Estimate monthly deposit from history
    const allDeposits=txns.filter(t=>t.type==='income');
    const months=new Set(allDeposits.map(t=>t.date.slice(0,7))).size||1;
    const avgMonthly=(g.saved||0)/months;
    const monthsLeft=avgMonthly>0 ? Math.ceil(remaining/avgMonthly) : null;
    return { ...g, remaining, monthsLeft, pct:Math.round((g.saved/g.target)*100) };
  });

  // Spending patterns: top recurring categories
  const catTotals={};
  txns.filter(t=>t.type==='expense').forEach(t=>{
    catTotals[t.category]=(catTotals[t.category]||0)+t.amount;
  });
  const topCats=Object.entries(catTotals).sort((a,b)=>b[1]-a[1]).slice(0,3);

  // Last 6 months net balance
  const last6months = Array.from({length:6}).map((_,i)=>{
    const d=new Date(); d.setMonth(d.getMonth()-5+i);
    const k=`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
    const inc=txns.filter(t=>t.type==='income'&&t.date?.startsWith(k)).reduce((s,t)=>s+t.amount,0);
    const exp=txns.filter(t=>t.type==='expense'&&t.date?.startsWith(k)).reduce((s,t)=>s+t.amount,0);
    return { label:d.toLocaleString('en',{month:'short'}).toUpperCase(), net:inc-exp, inc, exp };
  });

  // ── WEEKLY REPORT CARD ─────────────────────────────────────
  const weekStart=new Date(); weekStart.setDate(weekStart.getDate()-weekStart.getDay());
  const weekDates=Array.from({length:7}).map((_,i)=>{
    const d=new Date(weekStart); d.setDate(weekStart.getDate()+i);
    return d.toISOString().split('T')[0];
  });
  const weekTasks  = allTasks.filter(t=>weekDates.includes(t.date));
  const weekDone   = weekTasks.filter(t=>t.done).length;
  const weekTaskR  = weekTasks.length ? Math.round(weekDone/weekTasks.length*100) : 0;
  const weekWO     = workouts.filter(w=>weekDates.includes(w.date)).length;
  const weekIncome = txns.filter(t=>t.type==='income'&&weekDates.some(d=>t.date===d)).reduce((s,t)=>s+t.amount,0);
  const weekExp    = txns.filter(t=>t.type==='expense'&&weekDates.some(d=>t.date===d)).reduce((s,t)=>s+t.amount,0);
  const weekGoalsDone = monthGoals.filter(g=>g.done&&g.completedDate&&weekDates.includes(g.completedDate)).length;

  // Score each area 0-100
  const fitnessScore  = Math.min(100,Math.round(weekWO/WO_TARGET*100));
  const taskScore     = weekTaskR;
  const financeScore  = weekExp>0&&totalIncome>0 ? Math.min(100,Math.round((1-weekExp/totalIncome)*100+50)) : 50;
  const goalsScore    = weekGoalsDone>0 ? Math.min(100,weekGoalsDone*25) : 0;
  const weeklyScore   = Math.round((fitnessScore+taskScore+financeScore+goalsScore)/4);

  // Get last week's score for comparison
  const lastWeekKey = getWeekKey(new Date(weekStart.getTime()-7*864e5));
  const prevScore   = Store.get('weekScore_'+lastWeekKey, null);
  Store.set('weekScore_'+getWeekKey(weekStart), weeklyScore);

  return {
    tasks:    { todayRate:taskRate, highPending, procrastinated, last7Rates, avgRate7,
                worstDay, bestDay, avgDailyCompleted, backlogDays, soon, dayPerf, pendingAll },
    fitness:  { thisWeekWO:thisWeekWO.length, woRate, woStreak, totalWO, waterToday,
                overloadTips, weightTrend, last8wk },
    finance:  { totalIncome, totalExp, netBalance:totalIncome-totalExp,
                budgetAlerts, savingsRunway, topCats, last6months, monthPct:Math.round(monthPct*100) },
    weekly:   { score:weeklyScore, prevScore, taskScore, fitnessScore, financeScore, goalsScore,
                weekTaskR, weekWO, weekDone, weekGoalsDone },
    correlations: { taskWoCorr },
    player,
  };
}

function getWeekKey(d) {
  const s=new Date(d); s.setDate(s.getDate()-s.getDay());
  return s.toISOString().split('T')[0];
}

