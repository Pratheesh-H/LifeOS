// Apply end-of-day penalty for missed quests (called on load)
function applyMissedPenalties() {
  const tasks = Store.get('dailyTasks', []);
  const yesterday = new Date(); yesterday.setDate(yesterday.getDate() - 1);
  const yStr = yesterday.toISOString().split('T')[0];
  const penaltyApplied = Store.get('penaltyApplied_' + yStr, false);
  if (!penaltyApplied) {
    const missed = tasks.filter(t => t.date === yStr && !t.done);
    if (missed.length > 0) {
      let totalPenalty = missed.reduce((s, t) => s + (PENALTY_TABLE[t.priority || 'low']), 0);
      if (totalPenalty < 0) {
        addXP(totalPenalty);
        showNotif(`⚠ PENALTY: ${missed.length} missed quests — ${totalPenalty} XP`, 'red');
        sendBrowserNotif('QUEST PENALTY', `You missed ${missed.length} quests yesterday. ${totalPenalty} XP deducted.`, '💀');
      }
      Store.set('penaltyApplied_' + yStr, true);
    }
  }
}

