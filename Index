  /* ── SECTION CARDS ── */
  .section-card {
    margin-bottom: 16px;
    border: 1px solid var(--accent, var(--blue));
    background: rgba(0,0,0,0.3);
    page-break-inside: avoid;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
