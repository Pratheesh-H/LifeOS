  }
  .kp-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .kp-list li {
    font-family: 'Rajdhani', sans-serif;
    font-size: 10pt;
    color: var(--text);
    padding-left: 14px;
    position: relative;
    line-height: 1.5;
  }
  .kp-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--blue);
    font-size: 8pt;
  }

  /* recommendation box */
  .rec-box {
    margin-top: 10px;
    padding: 8px 12px;
    border-left: 3px solid var(--accent, var(--blue));
    background: color-mix(in srgb, var(--accent, var(--blue)) 6%, transparent);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .rec-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 7pt;
    letter-spacing: 2px;
    color: var(--accent, var(--blue));
  }
  .rec-text {
    font-family: 'Rajdhani', sans-serif;
    font-size: 11pt;
    font-weight: 600;
    color: var(--text);
    line-height: 1.5;
  }

  /* ── SUMMARY PAGE ── */
  .summary-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 20px;
  }
  .summary-card {
    border: 1px solid var(--border);
    padding: 12px;
    background: rgba(0,180,255,0.02);
  }
  .summary-card-title {
    font-family: 'Orbitron', monospace;
    font-size: 8pt;
    font-weight: 700;
    color: var(--blue);
    letter-spacing: 1px;
    margin-bottom: 8px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
